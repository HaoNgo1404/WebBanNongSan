@model WebWeb.Models.DotGiaoDinhKy
@{
    ViewData["Title"] = "Chi Tiết Đợt Giao Định Kỳ";
    Layout = "~/Views/Shared/_LayoutShipper.cshtml";
    
    // Lấy địa chỉ động từ gói đăng ký, nếu trống thì mặc định định vị về Hồ Chí Minh
    var diaChiGiaoHang = Model.Goi?.DiaChi?.DiaChiGiao ?? "Hồ Chí Minh";
}

<div class="container py-4">
    <div class="mb-3">
        <a asp-action="MyOrders" class="btn btn-link text-success p-0 fw-bold text-decoration-none">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách nhiệm vụ
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 bg-white p-3 rounded-3 mb-4">
                <div class="border-bottom pb-2 mb-3">
                    <h4 class="fw-bold text-dark mb-0">Đợt Giao #@Model.DotGiaoId</h4>
                    <div class="text-muted small mt-1">Mã Gói Tổng: <code class="text-danger">#@Model.GoiId</code></div>
                </div>

                <div class="mb-3">
                    <h6 class="fw-bold text-secondary"><i class="bi bi-person-bounding-box"></i> Người nhận:</h6>
                    <p class="fs-5 fw-semibold text-dark mb-1">@(Model.Goi?.KhachHang?.HoTen ?? "Khách hàng đăng ký gói")</p>
                </div>

                <div class="mb-3">
                    <h6 class="fw-bold text-secondary"><i class="bi bi-telephone-fill"></i> Số điện thoại:</h6>
                    <p class="fs-5 fw-semibold mb-1">
                        <a href="tel:@(Model.Goi?.KhachHang?.SoDienThoai)" class="text-success text-decoration-none">
                            <i class="bi bi-telephone-outbound"></i> @(Model.Goi?.KhachHang?.SoDienThoai ?? "Chưa có SĐT")
                        </a>
                    </p>
                </div>

                <div class="mb-3">
                    <h6 class="fw-bold text-secondary"><i class="bi bi-geo-alt-fill text-danger"></i> Địa chỉ giao hàng:</h6>
                    <p class="fw-semibold text-dark mb-1">@diaChiGiaoHang</p>
                </div>

                <div class="mb-3">
                    <h6 class="fw-bold text-secondary"><i class="bi bi-calendar-event"></i> Ngày dự kiến giao:</h6>
                    <span class="badge bg-light text-dark border fw-bold px-2 py-1.5">
                        @(Model.NgayGiaoThucTe.ToString("dd/MM/yyyy") ?? "Trong ngày")
                    </span>
                </div>

                <div class="mb-3 p-3 bg-light rounded-3 border border-dashed text-muted small">
                    <i class="bi bi-info-circle-fill text-info"></i> <strong>Lưu ý gói định kỳ:</strong> Khách đã trả tiền trước trực tuyến. Shipper phát đúng hàng và <strong>KHÔNG THU THÊM TIỀN MẶT (COD = 0đ)</strong>.
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-white p-3 rounded-3">
                <div class="text-center py-2">
                    <span class="text-muted d-block small mb-2">Trạng thái hiện tại:</span>
                    @if (Model.TrangThaiGiao == WebWeb.Models.OrderStatuses.ChoXuLy)
                    {
                        <span class="badge bg-warning text-dark px-3 py-2 fs-6">Đang chờ xử lý</span>
                    }
                    else if (Model.TrangThaiGiao == WebWeb.Models.OrderStatuses.DangGiao)
                    {
                        <span class="badge bg-info text-dark px-3 py-2 fs-6">Đang vận chuyển</span>
                    }
                    else if (Model.TrangThaiGiao == WebWeb.Models.OrderStatuses.HoanThanh)
                    {
                        <span class="badge bg-success px-3 py-2 fs-6">Giao thành công <i class="bi bi-check-all"></i></span>
                    }
                    else if (Model.TrangThaiGiao == WebWeb.Models.OrderStatuses.DaHuy)
                    {
                        <span class="badge bg-danger px-3 py-2 fs-6">Giao thất bại</span>
                    }

                    @if (Model.TrangThaiGiao == WebWeb.Models.OrderStatuses.DangGiao)
                    {
                        <hr class="my-3">
                        <div class="d-grid gap-2">
                            <form asp-action="CapNhatTrangThai" method="post">
                                <input type="hidden" name="id" value="@Model.DotGiaoId" />
                                <input type="hidden" name="trangThaiMoi" value="@WebWeb.Models.OrderStatuses.HoanThanh" />
                                <input type="hidden" name="type" value="dinhky" />
                                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold py-2.5 shadow-sm" onclick="return confirm('Xác nhận đợt giao này thành công?');">
                                    <i class="bi bi-check-circle-fill"></i> Giao thành công
                                </button>
                            </form>

                            <form asp-action="CapNhatTrangThai" method="post">
                                <input type="hidden" name="id" value="@Model.DotGiaoId" />
                                <input type="hidden" name="trangThaiMoi" value="@WebWeb.Models.OrderStatuses.DaHuy" />
                                <input type="hidden" name="type" value="dinhky" />
                                <button type="submit" class="btn btn-outline-danger w-100 fw-bold py-2" onclick="return confirm('Xác nhận báo đợt giao thất bại?');">
                                    <i class="bi bi-x-circle-fill"></i> Hủy (Không nhận hàng)
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0 h-100" style="min-height: 450px;">
                <div class="card-header bg-dark text-white fw-bold py-2.5">
                    <i class="bi bi-map"></i> Bản Đồ Dẫn Đường Thực Tế
                </div>
                <div class="card-body p-0 position-relative" style="height: 100%;">
                    <iframe 
                        width="100%" 
                        height="450" 
                        style="border:0;"
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://maps.google.com/maps?q=@(System.Net.WebUtility.UrlEncode((Model.Goi?.DiaChi?.DiaChiGiao ?? "Hồ Chí Minh") + ", Việt Nam"))&t=&z=15&ie=UTF8&iwloc=&output=embed">
                    </iframe>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-box-seam text-success"></i> Thông tin gói sản phẩm</h5>
                </div>
                <div class="card-body bg-white">
                    <p class="mb-2"><strong>Mã gói đăng ký:</strong> <span class="text-success fw-bold">@(Model.Goi?.GoiId)</span></p>
                    <p class="mb-2"><strong>Tần suất phát hàng:</strong> <span class="badge bg-secondary">@(Model.Goi?.TanSuatGiao ?? "Hằng tuần")</span></p>
                    @* <p class="mb-0"><strong>Ghi chú hệ thống:</strong> <span class="text-muted">@(Model.GoiDangKy?.GhiChu ?? "Không có ghi chú đặc biệt.")</span></p> *@
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border-style: dashed !important;
    }
</style>