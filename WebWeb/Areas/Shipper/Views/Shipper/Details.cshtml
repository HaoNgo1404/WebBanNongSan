@model WebWeb.Models.DonHangLe
@{
    ViewData["Title"] = "Chi Tiết Hành Trình Giao Hàng";
    Layout = "~/Views/Shared/_LayoutShipper.cshtml";
}

<div class="container py-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-link text-success p-0 fw-bold text-decoration-none">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách việc làm
        </a>
    </div>

    <div class="row">
        <!-- Cột bên trái: Chi tiết thông tin giao hàng & Nút bấm xử lý trạng thái -->
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 bg-white p-3 rounded-3">
                <div class="border-bottom pb-2 mb-3">
                    <h4 class="fw-bold text-dark mb-0">Đơn Hàng Giao #@Model.DonHangLeId</h4>
                    <span class="badge bg-primary mt-1">Trạng thái: @Model.TrangThaiDonHang</span>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold text-secondary"><i class="bi bi-person-bounding-box"></i> Người nhận:</h6>
                    <p class="fs-5 fw-semibold text-dark mb-1">@Model.NameCusNonAccount</p>
                    <p class="text-muted"><i class="bi bi-telephone-fill text-success"></i> Số điện thoại: @Model.PhoneNonAccount</p>

                    <h6 class="fw-bold text-secondary"><i class="bi bi-geo-alt-fill text-danger"></i> Điểm giao:</h6>
                    <p class="fw-medium text-dark bg-light p-2 rounded border">@Model.AddressNonAccount</p>
                    
                    <h6 class="fw-bold text-secondary"><i class="bi bi-wallet2"></i> Số tiền cần thu (COD):</h6>
                    <h4 class="text-danger fw-bold">@Model.TongTienTamTinh.ToString("N0") đ</h4>
                </div>

                <!-- BỘ HAI NÚT BẤM CẬP NHẬT TRẠNG THÁI -->
                @if (Model.TrangThaiDonHang == WebWeb.Models.OrderStatuses.DangGiao) 
                {
                    <div class="row g-2 border-top pt-3">
                        <div class="col-6">
                            <form asp-action="CapNhatTrangThai" method="post">
                                <input type="hidden" name="id" value="@Model.DonHangLeId" />
                                <input type="hidden" name="trangThaiMoi" value="@WebWeb.Models.OrderStatuses.HoanThanh" />
                                <input type="hidden" name="trangThaiThanhToanMoi" value="@WebWeb.Models.OrderStatuses.DaThanhToan" />
                                <button type="submit" class="btn btn-success w-100 py-2 fw-bold" onclick="return confirm('Xác nhận khách đã nhận hàng và trả đủ tiền?')">
                                    <i class="bi bi-check-circle-fill"></i> Đã Giao Thành Công
                                </button>
                            </form>
                        </div>
                        <div class="col-6">
                            <form asp-action="CapNhatTrangThai" method="post">
                                <input type="hidden" name="id" value="@Model.DonHangLeId" />
                                <input type="hidden" name="trangThaiMoi" value="@WebWeb.Models.OrderStatuses.DaHuy" />
                                <input type="hidden" name="trangThaiThanhToanMoi" value="@WebWeb.Models.OrderStatuses.ChuaThanhToan" />
                                <button type="submit" class="btn btn-danger w-100 py-2 fw-bold" onclick="return confirm('Xác nhận khách không nhận hoặc hủy đơn hàng?')">
                                    <i class="bi bi-x-circle-fill"></i> Hủy (Khách không nhận)
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Cột bên phải: Nhúng bản đồ đường đi Google Maps -->
        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0 h-100" style="min-height: 450px;">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-map"></i> Bản Đồ Dẫn Đường Thực Tế
                </div>
                <div class="card-body p-0 position-relative" style="height: 100%;">
                    <!-- Nhúng Iframe Google Maps tìm kiếm theo địa chỉ động của đơn hàng -->
                    <iframe 
                        width="100%" 
                        height="450" 
                        style="border:0;"
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://maps.google.com/maps?q=@(System.Net.WebUtility.UrlEncode((Model.AddressNonAccount ?? Model.DiaChi?.DiaChiGiao ?? "Hồ Chí Minh") + ", Việt Nam"))&t=&z=15&ie=UTF8&iwloc=&output=embed">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>