@{
    ViewData["Title"] = "Trạm Nhận Đơn Shipper";
    Layout = "~/Views/Shared/_LayoutShipper.cshtml";

    // Ép kiểu dữ liệu nhận từ ViewBag để bóc tách 2 luồng hàng
    var danhSachDonHangLe = ViewBag.DanhSachDonHangLe as IEnumerable<WebWeb.Models.DonHangLe>;
    var danhSachDotGiaoDinhKy = ViewBag.DanhSachDotGiaoDinhKy as IEnumerable<WebWeb.Models.DotGiaoDinhKy>;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold text-success"><i class="bi bi-truck"></i> Bảng Việc Shipper</h2>
            <p class="text-muted mb-0">Danh sách các đơn hàng lẻ và đợt giao định kỳ đang chờ tài xế tiếp nhận hệ thống.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <ul class="nav nav-pills mb-4 bg-light p-2 rounded-3 shadow-sm" id="shipperMarketTab" role="tablist">
        <li class="nav-item flex-fill text-center" role="presentation">
            <button class="nav-link w-100 active fw-bold text-uppercase rounded-3" id="cho-don-le-tab" data-bs-toggle="tab" data-bs-target="#cho-don-le" type="button" role="tab" aria-controls="cho-don-le" aria-selected="true">
                <i class="bi bi-bag-plus-fill me-1"></i> Đơn hàng lẻ sẵn có (@(danhSachDonHangLe?.Count() ?? 0))
            </button>
        </li>
        <li class="nav-item flex-fill text-center" role="presentation">
            <button class="nav-link w-100 fw-bold text-uppercase rounded-3 text-success" id="cho-dinh-ky-tab" data-bs-toggle="tab" data-bs-target="#cho-dinh-ky" type="button" role="tab" aria-controls="cho-dinh-ky" aria-selected="false">
                <i class="bi bi-calendar-plus-fill me-1"></i> Đợt định kỳ sẵn có (@(danhSachDotGiaoDinhKy?.Count() ?? 0))
            </button>
        </li>
    </ul>

    <div class="tab-content" id="shipperMarketTabContent">

        <div class="tab-pane fade show active" id="cho-don-le" role="tabpanel" aria-labelledby="cho-don-le-tab">
            <div class="row g-4">
                @if (danhSachDonHangLe == null || !danhSachDonHangLe.Any())
                {
                    <div class="col-12 text-center py-5 bg-white border rounded-3 shadow-sm">
                        <i class="bi bi-box-seam text-muted fs-1"></i>
                        <p class="text-muted mt-2 mb-0">Hiện tại không có đơn hàng lẻ nào đang chờ xử lý.</p>
                    </div>
                }
                else
                {
                    foreach (var item in danhSachDonHangLe)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-start border-4 border-warning shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h5 class="card-title fw-bold text-dark mb-0">Đơn hàng #@item.DonHangLeId</h5>
                                        <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                    </div>
                                    <hr class="my-2">
                                    <p class="mb-1 text-muted small"><i class="bi bi-person-fill"></i> <strong>Khách hàng:</strong> @item.NameCusNonAccount</p>
                                    <p class="mb-1 text-muted small"><i class="bi bi-geo-alt-fill text-danger"></i> <strong>Địa chỉ giao:</strong> @item.AddressNonAccount</p>
                                    <p class="mb-3 text-muted small"><i class="bi bi-cash-stack text-success"></i> <strong>Thu hộ COD:</strong> <span class="text-danger fw-bold">@item.TongTienTamTinh.ToString("N0") đ</span></p>
                                    
                                    <div class="mt-auto pt-2">
                                        <form asp-action="NhanDonHang" asp-route-id="@item.DonHangLeId" asp-route-type="le" method="post" onsubmit="return confirm('Bạn chắc chắn muốn nhận vận chuyển đơn hàng này chứ?');">
                                            <button type="submit" class="btn btn-success w-100 fw-bold">
                                                <i class="bi bi-check2-square"></i> Nhận đơn giao hàng
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="tab-pane fade" id="cho-dinh-ky" role="tabpanel" aria-labelledby="cho-dinh-ky-tab">
            <div class="row g-4">
                @if (danhSachDotGiaoDinhKy == null || !danhSachDotGiaoDinhKy.Any())
                {
                    <div class="col-12 text-center py-5 bg-white border rounded-3 shadow-sm">
                        <i class="bi bi-calendar-x text-muted fs-1"></i>
                        <p class="text-muted mt-2 mb-0">Hiện tại không có đợt giao định kỳ nào cần tài xế nhận lịch.</p>
                    </div>
                }
                else
                {
                    foreach (var item in danhSachDotGiaoDinhKy)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-start border-4 border-info shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h5 class="card-title fw-bold text-dark mb-0">Đợt Giao #@item.DotGiaoId</h5>
                                        <span class="badge bg-info text-dark">Đang chờ</span>
                                    </div>
                                    <div class="text-muted small mb-1">Mã Gói Tổng: <code class="text-danger">#@item.GoiId</code></div>
                                    <hr class="my-2">
                                    <p class="mb-1 text-muted small"><i class="bi bi-person-fill"></i> <strong>Khách hàng:</strong> @(item.Goi?.KhachHang?.HoTen ?? "Khách đăng ký gói")</p>
                                    <p class="mb-1 text-muted small"><i class="bi bi-geo-alt-fill text-danger"></i> <strong>Địa chỉ giao:</strong> @(item.Goi?.DiaChi?.DiaChiGiao ?? "Theo gói đăng ký")</p>
                                    <p class="mb-3 text-muted small"><i class="bi bi-calendar-event text-primary"></i> <strong>Ngày dự kiến giao:</strong> <span class="text-primary fw-bold">@(item.NgayGiaoThucTe.ToString("dd/MM/yyyy") ?? DateTime.Now.ToString("dd/MM/yyyy"))</span></p>
                                    
                                    <div class="mt-auto pt-2">
                                        <form asp-action="NhanDonHang" asp-route-id="@item.DotGiaoId" asp-route-type="dinhky" method="post" onsubmit="return confirm('Bạn chắc chắn muốn nhận lịch đợt giao định kỳ này?');">
                                            <button type="submit" class="btn btn-info text-dark w-100 fw-bold">
                                                <i class="bi bi-calendar-plus"></i> Nhận lịch đợt giao
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

    </div>
</div>

<style>
    /* CSS đồng bộ màu sắc quản lý Tab */
    .nav-pills .nav-link.active, .nav-pills .show > .nav-link {
        background-color: #198754 !important;
        color: #ffffff !important;
    }
    .nav-pills .nav-link {
        color: #6c757d;
        transition: all 0.2s ease-in-out;
    }
    .nav-pills .nav-link:hover {
        background-color: #e2e6ea;
    }
</style>