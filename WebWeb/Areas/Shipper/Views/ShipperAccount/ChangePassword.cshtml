@model WebWeb.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu tài xế";
    Layout = "~/Views/Shared/_LayoutShipper.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="admin-panel admin-form-panel p-4">
            <h4 class="fw-bold text-success mb-3"><i class="bi bi-shield-lock"></i> Đổi Mật Khẩu</h4>
            <p class="text-muted small">Để bảo mật tài khoản, vui lòng không chia sẻ mật khẩu làm việc cho người khác.</p>
            <hr class="my-3" />

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-2 small mb-3" role="alert">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <div>@TempData["SuccessMessage"]</div>
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label small fw-bold text-secondary">Mật Khẩu Hiện Tại</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                        <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu cũ" required />
                    </div>
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label small fw-bold text-secondary">Mật Khẩu Mới</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" required />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label small fw-bold text-secondary">Xác Nhận Mật Khẩu Mới</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success admin-btn px-4 shadow-sm">
                        <i class="bi bi-arrow-repeat"></i> Cập Nhật Mật Khẩu
                    </button>
                    <a asp-controller="Shipper" asp-action="Index" class="btn btn-light border admin-btn px-4">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>