@model WebWeb.Models.NhanVien
@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
    // Tự động dùng Layout của Shipper thay vì LayoutAdmin
}

<div class="admin-card p-4">
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">Hồ sơ tài khoản</h3>
        <p class="text-muted mb-0">Quản lý thông tin cá nhân và hành trình tác vụ của bạn trên hệ thống.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show p-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- CỘT TRÁI: AVATAR & TÓM TẮT -->
        <div class="col-lg-4">
            <div class="p-4 border rounded text-center bg-white shadow-sm">
                <!-- Tự động lấy chữ cái đầu tiên của tên tài xế giống Admin -->
                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold mx-auto mb-3" style="width: 80px; height: 80px; font-size: 32px;">
                    @Model.HoTen.Substring(0, 1).ToUpper()
                </div>
                <h4 class="fw-bold text-dark mb-1">@Model.HoTen</h4>
                
                <!-- Badge hiển thị Tên Vai Trò được lấy từ bảng liên kết VaiTroPhanQuyen -->
                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-semibold mb-3">
                    <i class="bi bi-truck me-1"></i> @(Model.VaiTro?.TenVaiTro ?? "Nhân viên giao hàng")
                </span>
                <hr />
                <div class="text-start small text-muted">
                    <p class="mb-2"><i class="bi bi-envelope me-2"></i> <strong>Email:</strong> @Model.Email</p>
                    <p class="mb-0"><i class="bi bi-toggle-on me-2"></i> <strong>Trạng thái:</strong> Hoạt động</p>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: FORM CHỈNH SỬA THÔNG TIN -->
        <div class="col-lg-8">
            <div class="p-4 border rounded bg-white shadow-sm">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="bi bi-person-gear me-2 text-success"></i>Thông tin chi tiết</h5>
                
                <!-- Đổi asp-action về hàm Profile của ShipperAccountController -->
                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Địa chỉ Email</label>
                        <input type="email" class="form-control bg-light" value="@Model.Email" disabled />
                        <small class="text-muted">Email dùng làm tài khoản đăng nhập cố định, không thể thay đổi.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark">Họ và Tên</label>
                        <input asp-for="HoTen" type="text" class="form-control" required />
                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4"><i class="bi bi-save me-1"></i> Lưu thay đổi</button>
                        <!-- Nút quay lại dẫn thẳng về trang nhận đơn của Shipper -->
                        <a class="btn btn-outline-secondary px-4" asp-area="Shipper" asp-controller="Shipper" asp-action="Index">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>