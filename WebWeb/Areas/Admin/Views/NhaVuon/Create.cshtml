@model WebWeb.Models.NhaVuon
@{
    ViewData["Title"] = "Thêm mới Nhà vườn";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Thêm mới đối tác nhà vườn</h2>
            <p class="text-muted mb-0">Ghi nhận thông tin vùng trồng và nhà cung cấp mới.</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="NhaVuon" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-form-panel">
        <form asp-area="Admin" asp-controller="NhaVuon" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tên nhà vườn</label>
                    <input asp-for="TenNhaVuon" class="form-control" placeholder="Nhập tên nhà vườn..." required />
                    <span asp-validation-for="TenNhaVuon" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Số điện thoại liên hệ</label>
                    <input asp-for="SoDienThoai" class="form-control" placeholder="Nhập số điện thoại..." />
                    <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Chứng nhận an toàn (VietGAP, GlobalGAP...)</label>
                    <input asp-for="ChungNhanAnToan" class="form-control" placeholder="Ví dụ: VietGAP 2026..." />
                    <span asp-validation-for="ChungNhanAnToan" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Địa chỉ vùng trồng</label>
                    <input asp-for="DiaChi" class="form-control" placeholder="Xã, Huyện, Tỉnh..." />
                    <span asp-validation-for="DiaChi" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Câu chuyện nhà vườn (Giới thiệu, quy trình canh tác...)</label>
                    <textarea asp-for="CauChuyenNhaVuon" class="form-control" rows="5" placeholder="Chia sẻ câu chuyện hoặc phương châm làm nông nghiệp hữu cơ của nhà vườn..."></textarea>
                    <span asp-validation-for="CauChuyenNhaVuon" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-success admin-btn px-4" type="submit"><i class="bi bi-save me-1"></i> Lưu thông tin</button>
                <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="NhaVuon" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</div>