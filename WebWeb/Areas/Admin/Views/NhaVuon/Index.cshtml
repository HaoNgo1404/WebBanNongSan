@model IEnumerable<WebWeb.Models.NhaVuon>
@{
    ViewData["Title"] = "Nhà vườn";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Nhà vườn đối tác</h2>
            <p class="text-muted mb-0">Quản lý thông tin nhà vườn, số điện thoại liên hệ và chứng nhận an toàn.</p>
        </div>
        <a class="btn btn-success admin-btn" asp-area="Admin" asp-controller="NhaVuon" asp-action="Create"><i class="bi bi-plus-lg"></i> Thêm mới</a>
    </div>

    <div class="admin-panel p-4">
        <form method="get" asp-area="Admin" asp-controller="NhaVuon" asp-action="Index">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                <div class="position-relative" style="max-width: 360px; width: 100%;">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                    <input class="form-control ps-5" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tìm tên nhà vườn hoặc SĐT..." />
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-outline-secondary btn-sm admin-btn">Tìm kiếm</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên nhà vườn</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ</th>
                        <th>Chứng nhận an toàn</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>#NV-@item.NhaVuonId</td>
                                <td class="fw-semibold text-dark">@item.TenNhaVuon</td>
                                <td class="fw-medium">@(string.IsNullOrEmpty(item.SoDienThoai) ? "Chưa có" : item.SoDienThoai)</td>
                                <td class="text-truncate" style="max-width: 200px;">@(string.IsNullOrEmpty(item.DiaChi) ? "Chưa có" : item.DiaChi)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ChungNhanAnToan))
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1"><i class="bi bi-shield-check me-1"></i> @item.ChungNhanAnToan</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border px-2 py-1">Chưa cập nhật</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="NhaVuon" asp-action="Details" asp-route-id="@item.NhaVuonId"><i class="bi bi-eye"></i></a>
                                        <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="NhaVuon" asp-action="Edit" asp-route-id="@item.NhaVuonId"><i class="bi bi-pencil"></i></a>
                                        <a class="btn btn-outline-danger btn-sm" asp-area="Admin" asp-controller="NhaVuon" asp-action="Delete" asp-route-id="@item.NhaVuonId"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Không tìm thấy thông tin nhà vườn nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>