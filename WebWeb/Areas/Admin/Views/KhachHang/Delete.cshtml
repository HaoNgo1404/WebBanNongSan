@model WebWeb.Models.KhachHang
@{
    ViewData["Title"] = "Xác nhận xóa tài khoản khách hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml"; // Hào đổi lại tên Layout Admin thực tế của bạn nếu cần
}

<div class="container-fluid px-4 py-4">
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-action="Index" class="text-success text-decoration-none fw-semibold">Quản lý khách hàng</a></li>
        <li class="breadcrumb-item active">Xác nhận xóa</li>
    </ol>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white py-3 border-0 rounded-top-4">
                    <h5 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> CẢNH BÁO XÓA TÀI KHOẢN
                    </h5>
                </div>
                <div class="card-body p-4 bg-white">
                    <p class="text-secondary mb-4 fs-6">
                        Hào có chắc chắn muốn xóa vĩnh viễn tài khoản khách hàng này không? Hành động này sẽ loại bỏ thông tin tài khoản khỏi hệ thống và không thể hoàn tác.
                    </p>

                    <div class="p-3 bg-light rounded-3 border mb-4">
                        <h6 class="text-success border-bottom pb-2 mb-3 fw-bold">Thông tin khách hàng:</h6>
                        <div class="row g-2 small">
                            <div class="col-4 fw-bold text-dark">Mã khách hàng:</div>
                            <div class="col-8 text-secondary">#@Model.KhachHangId</div>

                            <div class="col-4 fw-bold text-dark">Họ và tên:</div>
                            <div class="col-8 text-secondary fw-semibold">@Model.HoTen</div>

                            <div class="col-4 fw-bold text-dark">Số điện thoại:</div>
                            <div class="col-8 text-secondary">@Model.SoDienThoai</div>

                            <div class="col-4 fw-bold text-dark">Địa chỉ Email:</div>
                            <div class="col-8 text-secondary text-break">@Model.Email</div>

                            <div class="col-4 fw-bold text-dark">Điểm tích lũy:</div>
                            <div class="col-8"><span class="badge bg-info text-dark">@Model.DiemTichLuy điểm</span></div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="KhachHangId" />

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-bold text-secondary">
                                <i class="bi bi-arrow-left-short"></i> Hủy thao tác
                            </a>
                            <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">
                                <i class="bi bi-trash3-fill"></i> Xác nhận xóa ngay
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>