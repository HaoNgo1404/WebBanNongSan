@model IEnumerable<WebWeb.Models.KhachHang>
@{
    ViewData["Title"] = "Quản Lý Khách Hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Quản lý hồ sơ khách hàng</h3>
            <p class="text-muted mb-0">Xem danh sách tài khoản thành viên, điểm tích lũy và quản lý lịch sử mua hàng hệ thống.</p>
        </div>
    </div>

    <div class="admin-panel p-4">
        <form method="get" asp-action="Index" class="mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                <div class="position-relative" style="max-width: 400px; width: 100%;">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                    <input class="form-control ps-5" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tìm tên, số điện thoại hoặc email..." />                 
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-outline-secondary btn-sm admin-btn">Tìm kiếm</button>
                </div>
            </div>
        </form>

        

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Mã KH</th>
                        <th>Họ Và Tên</th>
                        <th>Thông Tin Liên Hệ</th>
                        <th>Ngày Đăng Ký</th>
                        <th>Điểm Tích Lũy</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">#KH-@item.KhachHangId</td>
                                <td class="fw-semibold text-dark">@item.HoTen</td>
                                <td class="contact-info">
                                    <div><i class="bi bi-telephone me-1 text-muted"></i> @item.SoDienThoai</div>
                                    @if (!string.IsNullOrEmpty(item.Email))
                                    {
                                        <small class="text-muted"><i class="bi bi-envelope me-1"></i> @item.Email</small>
                                    }
                                </td>
                                <td>@item.NgayDangKy.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 fw-bold">
                                        <i class="bi bi-star-fill me-1"></i> @item.DiemTichLuy điểm
                                    </span>
                                </td>
                                <td>
                                    <a class="btn btn-outline-secondary btn-sm rounded-2 px-3" asp-action="Details" asp-route-id="@item.KhachHangId">
                                        <i class="bi bi-eye"></i> Xem hồ sơ
                                    </a>
                                    <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="KhachHang" asp-action="Edit" asp-route-id="@item.KhachHangId"><i class="bi bi-pencil"></i> Sửa</a>
                                    @* <a asp-area="Admin" asp-controller="KhachHang" asp-action="Delete" asp-route-id="@item.KhachHangId" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a> *@
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Không tìm thấy thành viên nào phù hợp.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>