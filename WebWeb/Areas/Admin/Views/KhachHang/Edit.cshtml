@model WebWeb.Models.KhachHang
@{
    ViewData["Title"] = "Sửa Hồ Sơ Khách Hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Chỉnh sửa thông tin thành viên</h3>
            <p class="text-muted mb-0">Thay đổi hồ sơ liên hệ hoặc điều chỉnh điểm tích lũy của khách hàng.</p>
        </div>
        <a class="btn btn-outline-secondary rounded-2 btn-sm" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-form-panel p-4 border rounded-3 bg-white">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="KhachHangId" />

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="HoTen" class="form-label fw-medium text-dark">Họ và tên khách hàng</label>
                    <input asp-for="HoTen" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="DiemTichLuy" class="form-label fw-medium text-dark">Điểm hạng thành viên</label>
                    <input asp-for="DiemTichLuy" class="form-control" type="number" required />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="SoDienThoai" class="form-label fw-medium text-dark">Số điện thoại liên hệ</label>
                    <input asp-for="SoDienThoai" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-medium text-dark">Địa chỉ Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4 rounded-2">Cập nhật hồ sơ</button>
                <a class="btn btn-outline-secondary px-4 rounded-2" asp-action="Index">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>