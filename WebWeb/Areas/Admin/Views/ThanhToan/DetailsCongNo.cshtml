@model IEnumerable<WebWeb.Models.PhieuNhapKho>
@{
    ViewData["Title"] = "Chi tiết đối soát công nợ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid px-4 py-3">
    <div class="mb-3">
        <a asp-action="DanhSachCongNo" class="btn btn-link text-success p-0 fw-bold text-decoration-none">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách công nợ
        </a>
    </div>

    <div class="admin-card p-4 bg-white rounded-3 shadow-sm mb-4">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1"><i class="bi bi-journal-text text-success"></i> Chi tiết lịch sử công nợ nhà vườn</h3>
                <p class="text-muted mb-0">Đối tác liên kết: <strong class="text-dark">@ViewBag.TenNhaVuon</strong></p>
            </div>
            <div class="text-end">
                <span class="text-muted small d-block">Dư nợ hiện tại cần tất toán</span>
                <span class="fs-4 fw-bold text-danger">@(((decimal)ViewBag.CongNoConLai).ToString("#,##0")) đ</span>
            </div>
        </div>

        <!-- Khối thống kê tổng quan -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="p-3 bg-light border rounded-3">
                    <span class="text-muted small d-block mb-1">Tổng giá trị nông sản đã nhập</span>
                    <strong class="fs-5 text-dark">@(((decimal)ViewBag.TongTienNhap).ToString("#,##0")) đ</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 bg-light border rounded-3">
                    <span class="text-muted small d-block mb-1">Tổng tiền hệ thống đã giải ngân</span>
                    <strong class="fs-5 text-success">@(((decimal)ViewBag.TongTienDaChi).ToString("#,##0")) đ</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 bg-danger-subtle border border-danger-subtle rounded-3">
                    <span class="text-danger small d-block mb-1">Công nợ tích lũy còn tồn</span>
                    <strong class="fs-5 text-danger">@(((decimal)ViewBag.CongNoConLai).ToString("#,##0")) đ</strong>
                </div>
            </div>
        </div>

        <h5 class="fw-bold text-secondary mb-3">Danh sách các phiếu nhập kho cấu thành</h5>
        <div class="admin-panel p-3 bg-light border rounded-3">
            <div class="table-responsive">
                <table class="table table-hover align-middle bg-white rounded mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã Phiếu Nhập</th>
                            <th>Ngày Lập Phiếu</th>
                            <th>Nhân Viên Nhập Kho</th>
                            <th class="text-end pe-4">Tổng Tiền Nhập</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var pn in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">#PNK-@pn.PhieuNhapId</td>
                                    <td>@pn.NgayLapPhieu.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@pn.NhanVien?.HoTen</td>
                                    <td class="text-end pe-4 fw-bold text-dark">@pn.TongTienNhap.ToString("#,##0") đ</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">Không tìm thấy lịch sử phiếu nhập kho nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>