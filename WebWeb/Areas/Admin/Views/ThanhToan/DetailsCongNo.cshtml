@model WebWeb.Models.PhieuChiCongNo
@{
    ViewData["Title"] = "Chi tiết Phiếu chi";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Chi tiết phiếu chi công nợ</h3>
            <p class="text-muted mb-0">Hồ sơ chứng từ thanh toán tiền nhập nông sản cho đối tác Nhà vườn.</p>
        </div>
        <a class="btn btn-outline-secondary btn-sm rounded-2" asp-action="DanhSachCongNo"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="p-4 border rounded-3 bg-white">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="text-muted small d-block">Mã số chứng từ</label>
                <span class="fw-bold text-dark fs-5">#PC-@Model.PhieuChiId</span>
            </div>
            <div class="col-md-6 mb-3 text-md-end">
                <label class="text-muted small d-block">Trạng thái tất toán</label>
                @if (!string.IsNullOrEmpty(Model.MaGiaoDich))
                {
                    <span class="badge bg-success text-white px-3 py-2"><i class="bi bi-check-circle"></i> Đã hoàn thành chi trả</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-exclamation-circle"></i> Đang chờ xử lý chuyển tiền</span>
                }
            </div>
        </div>
        <hr class="my-3"/>
        <div class="row g-3">
            <div class="col-sm-6">
                <p class="mb-2"><strong>Đơn vị thụ hưởng (Nhà Vườn):</strong> @Model.NhaVuon.TenNhaVuon</p>
                <p class="mb-2"><strong>Địa chỉ nhà cung ứng:</strong> @Model.NhaVuon.DiaChi</p>
                <p class="mb-0"><strong>Số điện thoại:</strong> @Model.NhaVuon.SoDienThoai</p>
            </div>
            <div class="col-sm-6 border-start ps-4">
                <p class="mb-2"><strong>Nhân viên kế toán lập phiếu:</strong> @Model.NhanVien.HoTen</p>
                <p class="mb-2"><strong>Ngày lập phiếu chứng từ:</strong> @Model.NgayLap.ToString("dd/MM/yyyy HH:mm")</p>
                <p class="mb-2"><strong>Hình thức thanh toán cam kết:</strong> @(Model.PhuongThuc == 1 ? "Chuyển khoản Ngân hàng" : "Chi tiền mặt tại quầy")</p>
                <p class="mb-0"><strong>Mã chuẩn chi ngân hàng:</strong> <code class="text-dark fw-bold fs-6">@(string.IsNullOrEmpty(Model.MaGiaoDich) ? "Chưa có" : Model.MaGiaoDich)</code></p>
            </div>
        </div>
        <div class="mt-4 p-3 bg-light rounded text-end">
            <span class="text-muted me-2">Tổng số tiền thực chi:</span>
            <span class="text-danger fw-bold fs-4">@Model.SoTienThucChi.ToString("#,##0") VNĐ</span>
        </div>
    </div>
</div>