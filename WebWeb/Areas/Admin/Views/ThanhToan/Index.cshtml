@model IEnumerable<WebWeb.Models.GiaoDichThanhToan>
@{
    ViewData["Title"] = "Quản lý Thanh toán";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex border-bottom mb-4">
        <a class="nav-link active fw-bold text-success border-bottom border-2 border-success pb-2 pe-3" asp-action="Index">Quản lý thanh toán đơn hàng</a>
        <a class="nav-link text-muted pb-2 ps-3" asp-action="DanhSachCongNo">Danh sách công nợ Nhà vườn</a>
        <a class="nav-link text-muted pb-2 ps-3" asp-action="LichSuPhieuChi">Lịch sử phiếu chi công nợ</a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Lịch sử thanh toán hóa đơn</h3>
            <p class="text-muted mb-0">Danh sách các giao dịch thanh toán trực tuyến từ khách hàng mua lẻ hoặc đăng ký gói.</p>
        </div>
    </div>

    <div class="admin-panel p-4 bg-white border rounded-3">
        <form method="get" asp-area="Admin" asp-controller="ThanhToan" asp-action="Index">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                <div class="position-relative" style="max-width: 380px;">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                    <input class="form-control ps-5" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tìm theo mã giao dịch, khách hàng..." />
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-outline-secondary btn-sm admin-btn">Tìm kiếm</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <div class="thanhtoan-container" style="max-height: 380px; overflow-y: auto; padding-right: 8px;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Mã Giao Dịch Cổng</th>
                            <th>Khách Hàng</th>
                            <th>Số Tiền</th>
                            <th>Phương Thức</th>
                            <th>Ngày Giao Dịch</th>
                            <th>Trạng Thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-monospace fw-bold text-secondary">@item.MaGiaoDichCong</td>
                                <td>@(item.DonHangLe?.KhachHang?.HoTen ?? item.GoiDangKy?.KhachHang?.HoTen ?? item.DonHangLe?.NameCusNonAccount)</td>
                                <td class="text-success fw-bold">@item.SoTien.ToString("#,##0") đ</td>
                                <td><span class="badge bg-light text-dark border">@item.PhuongThuc</span></td>
                                <td>@item.NgayGiaoDich.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.TrangThai == 1)
                                    {
                                        <span class="badge bg-success-subtle text-success p-2"><i class="bi bi-check-circle"></i> Thành công</span>
                                    }
                                    else if (item.TrangThai == 2)
                                    {
                                        <span class="badge bg-warning-subtle text-warning p-2"><i class="bi bi-exclamation-circle"></i> Hoàn tiền</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger p-2"><i class="bi bi-x-circle"></i> Thất bại</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="DetailsGiaoDich" asp-route-id="@item.GiaoDichId" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>