@model WebWeb.Models.GiaoDichThanhToan
@{
    ViewData["Title"] = "Chi tiết Giao dịch";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Chi tiết giao dịch cổng thanh toán</h3>
            <p class="text-muted mb-0">Thông tin nhận tiền trực tuyến ghi nhận từ hệ thống.</p>
        </div>
        <a class="btn btn-outline-secondary btn-sm rounded-2" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="row g-4">
        <div class="col-md-7">
            <div class="p-4 border rounded-3 bg-white mb-4">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Thông tin dòng tiền</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted fw-normal mb-3">Mã Giao dịch hệ thống:</dt>
                    <dd class="col-sm-8 text-dark fw-bold mb-3">#GD-@Model.GiaoDichId</dd>

                    <dt class="col-sm-4 text-muted fw-normal mb-3">Mã Cổng (VNPAY/MOMO):</dt>
                    <dd class="col-sm-8 text-success font-monospace fw-bold mb-3">@Model.MaGiaoDichCong</dd>

                    <dt class="col-sm-4 text-muted fw-normal mb-3">Số tiền nhận về:</dt>
                    <dd class="col-sm-8 text-dark fw-bold fs-5 mb-3">@Model.SoTien.ToString("#,##0") đ</dd>

                    <dt class="col-sm-4 text-muted fw-normal mb-3">Phương thức qua:</dt>
                    <dd class="col-sm-8 mb-3"><span class="badge bg-light text-dark border">@Model.PhuongThuc</span></dd>

                    <dt class="col-sm-4 text-muted fw-normal mb-3">Thời gian ghi nhận:</dt>
                    <dd class="col-sm-8 text-dark mb-3">@Model.NgayGiaoDich.ToString("dd/MM/yyyy HH:mm:ss")</dd>

                    <dt class="col-sm-4 text-muted fw-normal">Trạng thái xử lý:</dt>
                    <dd class="col-sm-8">
                        @(Model.TrangThai == 1 ? "Thành công công nhận dòng tiền" : "Thất bại / Đã hủy hủy bỏ")
                    </dd>
                </dl>
            </div>
        </div>
        
        <div class="col-md-5">
            <div class="p-4 border rounded-3 bg-white">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Liên kết đơn hàng</h5>
                @if(Model.DonHangLe != null)
                {
                    <p class="mb-2"><strong>Mã Đơn hàng:</strong> #DH-@Model.DonHangLeId</p>
                    <p class="mb-2"><strong>Khách hàng:</strong> @(Model.DonHangLe.KhachHang?.HoTen ?? "Khách đặt nhanh")</p>
                    <p class="mb-0"><strong>Số điện thoại:</strong> @(Model.DonHangLe.KhachHang?.SoDienThoai ?? Model.DonHangLe.PhoneNonAccount)</p>
                }
                else
                {
                    <p class="text-muted mb-0">Giao dịch thuộc về gói Đăng ký định kỳ (Subscription).</p>
                }
            </div>
        </div>
    </div>
</div>