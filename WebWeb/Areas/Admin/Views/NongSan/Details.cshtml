@model WebWeb.Models.NongSan
@{
    ViewData["Title"] = "Chi tiết Nông sản";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Chi tiết nông sản</h2>
            <p class="text-muted mb-0">Xem toàn bộ thông tin chi tiết lưu trong hệ thống.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="NongSan" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
            <a class="btn btn-success admin-btn" asp-area="Admin" asp-controller="NongSan" asp-action="Edit" asp-route-id="@Model.NongSanId"><i class="bi bi-pencil"></i> Chỉnh sửa</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-panel p-4">
                <h5 class="fw-semibold mb-3 text-success"><i class="bi bi-info-circle me-2"></i>Thông tin chính</h5>
                
                @if (!string.IsNullOrWhiteSpace(Model.HinhAnh))
                {
                    <div class="mb-4">
                        <label class="form-label text-muted d-block">Hình ảnh nông sản</label>
                        <img src="@Url.Content("~/images/" + Model.HinhAnh)" alt="@Model.TenNongSan" class="rounded-3 shadow-sm border" style="max-width: 200px; height: 150px; object-fit: cover;" />
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted mb-1">Tên nông sản</label>
                        <div class="p-2 border rounded bg-light fw-semibold">@Model.TenNongSan</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted mb-1">Danh mục</label>
                        <div class="p-2 border rounded bg-light">@(Model.DanhMuc?.TenDanhMuc ?? "Chưa phân loại")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted mb-1">Nhà vườn cung cấp</label>
                        <div class="p-2 border rounded bg-light">@(Model.NhaVuon?.TenNhaVuon ?? "Chưa rõ")</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted mb-1">Giá bán niêm yết</label>
                        <div class="p-2 border rounded bg-light text-success fw-bold">@Model.GiaBanNiemYet.ToString("#,##0") đ</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted mb-1">Đơn vị tính</label>
                        <div class="p-2 border rounded bg-light">@Model.DonViTinh</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted mb-1">Sai số cho phép</label>
                        <div class="p-2 border rounded bg-light">± @Model.SaiSoChoPhep %</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted mb-1">Mô tả chi tiết</label>
                        <div class="p-3 border rounded bg-light" style="white-space: pre-line;">
                            @(string.IsNullOrWhiteSpace(Model.MoTa) ? "Không có mô tả." : Model.MoTa)
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="admin-panel p-4">
                <h5 class="fw-semibold mb-3 text-secondary"><i class="bi bi-tags me-2"></i>Hệ thống</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2 py-2 border-bottom"><strong>Mã bản ghi:</strong> <span class="badge bg-dark float-end">#NS-@Model.NongSanId</span></li>
                    <li class="py-2"><strong>Cổng quản trị:</strong> <span class="badge bg-success float-end">Fresh Farm Admin</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>