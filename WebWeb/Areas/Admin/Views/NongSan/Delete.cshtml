@model WebWeb.Models.NongSan
@{
    ViewData["Title"] = "Xóa Nông sản";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Xác nhận xóa nông sản</h2>
            <p class="text-muted mb-0">Hành động này không thể hoàn tác sau khi thực hiện.</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="NongSan" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-empty-state text-center py-5 border rounded bg-white shadow-sm">
        <div class="mb-3 text-danger"><i class="bi bi-trash3" style="font-size: 3.5rem;"></i></div>
        <h4 class="fw-bold text-dark mb-2">Bạn thực sự muốn xóa nông sản này?</h4>
        <p class="text-muted mb-4">Mục <strong class="text-danger">@Model.TenNongSan</strong> (#NS-@Model.NongSanId) thuộc danh mục <strong>@(Model.DanhMuc?.TenDanhMuc ?? "Chưa rõ")</strong> sẽ bị gỡ bỏ khỏi hệ thống.</p>
        
        <form asp-area="Admin" asp-controller="NongSan" asp-action="Delete" method="post" class="d-inline-block">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="NongSanId" name="id" />
            <div class="d-flex gap-2 justify-content-center">
                <button type="submit" class="btn btn-danger admin-btn px-4"><i class="bi bi-exclamation-triangle me-1"></i> Xác nhận xóa</button>
                <a class="btn btn-outline-secondary admin-btn px-4" asp-area="Admin" asp-controller="NongSan" asp-action="Index">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>