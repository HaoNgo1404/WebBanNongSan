@model WebWeb.Models.NongSan
@{
    ViewData["Title"] = "Chỉnh sửa Nông sản";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Chỉnh sửa nông sản</h2>
            <p class="text-muted mb-0">Cập nhật thông tin cho nông sản #NS-@Model.NongSanId</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="NongSan" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-form-panel">
        <form asp-area="Admin" asp-controller="NongSan" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="NongSanId" />

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tên nông sản</label>
                    <input asp-for="TenNongSan" class="form-control" required />
                    <span asp-validation-for="TenNongSan" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Danh mục nông sản</label>
                    <select asp-for="DanhMucId" class="form-select" asp-items="ViewBag.DanhMucId" required></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Nhà vườn cung cấp</label>
                    <select asp-for="NhaVuonId" class="form-select" asp-items="ViewBag.NhaVuonId" required></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Giá bán niêm yết (đ)</label>
                    <input asp-for="GiaBanNiemYet" class="form-control" type="number" step="0.01" min="0" required />
                    <span asp-validation-for="GiaBanNiemYet" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Đơn vị tính</label>
                    <input asp-for="DonViTinh" class="form-control" required />
                    <span asp-validation-for="DonViTinh" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Sai số cho phép (%)</label>
                    <input asp-for="SaiSoChoPhep" class="form-control" type="number" min="0" required />
                    <span asp-validation-for="SaiSoChoPhep" class="text-danger small"></span>
                </div>
                <div class="col-md-9">
                    <label class="form-label fw-semibold">Đường dẫn Hình ảnh (URL)</label>
                    <input asp-for="HinhAnh" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Mô tả sản phẩm</label>
                    <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-success admin-btn px-4" type="submit"><i class="bi bi-check-circle me-1"></i> Cập nhật</button>
                <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="NongSan" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</div>