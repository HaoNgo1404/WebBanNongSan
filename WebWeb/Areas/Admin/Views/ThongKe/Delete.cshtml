@{
    ViewData["Title"] = "Xóa Thống kê";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Xác nhận xóa thống kê</h2>
            <p class="text-muted mb-0">Mẫu xác nhận trước khi thực hiện thao tác xóa.</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-empty-state">
        <div><i class="bi bi-trash3"></i></div>
        <div class="fw-semibold mb-2">Bạn có chắc chắn muốn xóa mục này?</div>
        <p class="text-muted mb-0">Mục #THONGKE-001 sẽ bị ẩn khỏi hệ thống sau thao tác này.</p>
    </div>

    <div class="d-flex gap-2 flex-wrap mt-4">
        <button class="btn btn-danger admin-btn" type="button">Xác nhận xóa</button>
        <a class="btn btn-outline-secondary admin-btn" href="@Url.Action("Index")">Hủy</a>
    </div>

    <div class="alert alert-light border mt-4 mb-0">
        <small><strong>TODO:</strong> Thay hành động xóa mẫu bằng logic thật khi backend sẵn sàng.</small>
    </div>
</div>
