@{
    ViewData["Title"] = "Chỉnh sửa Thống kê";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Chỉnh sửa thống kê</h2>
            <p class="text-muted mb-0">Mẫu form chỉnh sửa dùng cho module thống kê.</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-form-panel">
        <form>
            <div class="admin-form-grid">
                <div class="mb-3">
                    <label class="form-label">Tên thống kê</label>
                    <input class="form-control" value="Ví dụ thống kê" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Trạng thái</label>
                    <select class="form-select">
                        <option selected>Hoạt động</option>
                        <option>Ẩn</option>
                        <option>Chờ duyệt</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea class="form-control" rows="4">Xem báo cáo tổng hợp và xu hướng hoạt động.</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ngày cập nhật</label>
                    <input class="form-control" type="date" value="2026-06-28" />
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-success admin-btn" type="button">Cập nhật</button>
                <a class="btn btn-outline-secondary admin-btn" href="@Url.Action("Index")">Hủy</a>
            </div>
        </form>
    </div>
</div>
