@model IEnumerable<WebWeb.Models.DonHangLe>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng Lẻ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="admin-card p-4">
    <div class="d-flex border-bottom mb-4">
        <a class="nav-link active fw-bold text-success border-bottom border-2 border-success pb-2 pe-3 text-decoration-none" 
           asp-area="Admin" asp-controller="DonHang" asp-action="Index">Đơn hàng lẻ</a>
        <a class="nav-link text-muted pb-2 ps-3 text-decoration-none" 
           asp-area="Admin" asp-controller="DonHang" asp-action="IndexDinhKy">Đơn hàng định kỳ</a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Danh sách đơn hàng lẻ</h3>
            <p class="text-muted mb-0">Quản lý toàn bộ các đơn hàng mua lẻ trực tiếp từ khách hàng hệ thống và vãng lai.</p>
        </div>
    </div>

    <div class="admin-panel p-4">
        <form method="get" asp-area="Admin" asp-controller="DonHang" asp-action="Index" class="mb-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                <div class="position-relative" style="max-width: 400px; width: 100%;">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                    <input class="form-control ps-5" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tìm kiếm đơn hàng..." />                 
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-outline-secondary btn-sm admin-btn">Tìm kiếm</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <div class="donhang-container" style="max-height: 380px; overflow-y: auto; padding-right: 8px;">
                <table class="admin-table">
                    <thead>
                        <tr class="text-nowrap">
                            <th>Mã Đơn</th>
                            <th>Khách Hàng</th>
                            <th>SĐT</th>
                            <th>Ngày Đặt</th>
                            <th>Khung Giờ Giao</th>
                            <th>Tổng Tiền</th>
                            <th>Thanh Toán</th>
                            <th>Trạng Thái</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">#DHL-@item.DonHangLeId</td>
                                    <td>
                                        @if (item.KhachHangId != null && item.KhachHang != null)
                                        {
                                            @item.KhachHang.HoTen
                                        }
                                        else
                                        {
                                            @item.NameCusNonAccount
                                        }
                                    </td>
                                    <td>
                                        @(item.KhachHangId != null ? item.KhachHang?.SoDienThoai : item.PhoneNonAccount)
                                    </td>
                                    <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge bg-light text-dark border">@item.KhungGioGiaoHang</span></td>
                                    <td class="text-success fw-bold">@((item.TongTienThucTe ?? item.TongTienTamTinh).ToString("#,##0")) đ</td>
                                    <td>
                                        @if (item.TrangThaiThanhToan == WebWeb.Models.OrderStatuses.DaThanhToan)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Đã thanh toán</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1">Chờ thanh toán</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.TrangThaiDonHang)
                                        {
                                            case WebWeb.Models.OrderStatuses.ChoDuyet:
                                                <span class="text-info fw-medium"><i class="bi bi-file-earmark-text"></i> Chờ duyệt</span>
                                                break;
                                            case WebWeb.Models.OrderStatuses.ChoXuLy:
                                                <span class="text-warning fw-medium"><i class="bi bi-clock-history"></i> Chờ xử lý</span>
                                                break;
                                            case WebWeb.Models.OrderStatuses.DangGiao:
                                                <span class="text-primary fw-medium"><i class="bi bi-truck"></i> Đang giao</span>
                                                break;
                                            case WebWeb.Models.OrderStatuses.HoanThanh:
                                                <span class="text-success fw-medium"><i class="bi bi-check-circle-fill"></i> Đã giao</span>
                                                break;
                                            case WebWeb.Models.OrderStatuses.DaHuy:
                                                <span class="text-danger fw-medium"><i class="bi bi-x-circle-fill"></i> Đã hủy</span>
                                                break;
                                            default:
                                                <span class="text-secondary fw-medium">@item.TrangThaiDonHang</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-nowrap">
                                        <a class="btn btn-outline-secondary btn-sm rounded-2 px-3 text-nowrap" asp-area="Admin" asp-controller="DonHang" asp-action="Details" asp-route-id="@item.DonHangLeId">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>
                                        
                                        @if (item.TrangThaiDonHang == WebWeb.Models.OrderStatuses.ChoDuyet) {
                                            // Chuẩn bị dữ liệu danh sách sản phẩm để truyền vào HTML attribute
                                            var dsSanPham = item.ChiTietDonHangLes?.Select(ct => new {
                                                ten = ct.NongSan?.TenNongSan ?? "Nông sản",
                                                soluong = ct.SoLuongDat,
                                                dvt = ct.NongSan?.DonViTinh ?? "kg"
                                            }).ToList();
                                            
                                            var jsonSanPham = System.Text.Json.JsonSerializer.Serialize(dsSanPham);

                                            <button class="btn btn-sm btn-success rounded-3 btn-duyet-don" 
                                                    data-id="@item.DonHangLeId"
                                                    data-total="@item.TongTienTamTinh.ToString("#,##0")"
                                                    data-products='@jsonSanPham'>
                                                <i class="bi bi-check-circle-fill"></i> Duyệt đơn
                                            </button>
                                        }

                                        <a asp-action="Delete" asp-route-id="@item.DonHangLeId" class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="bi bi-trash"></i> Xóa đơn
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">Không có đơn hàng lẻ nào trong hệ thống.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const duyetButtons = document.querySelectorAll('.btn-duyet-don');

            duyetButtons.forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault();
                    
                    const donHangId = this.getAttribute('data-id');
                    const tongTien = this.getAttribute('data-total');
                    
                    // Bốc và giải mã chuỗi danh sách sản phẩm
                    const rawProducts = this.getAttribute('data-products');
                    let productsList = [];
                    try {
                        productsList = JSON.parse(rawProducts) || [];
                    } catch (err) {
                        console.error("Lỗi đọc dữ liệu sản phẩm:", err);
                    }

                    // Dựng bảng HTML hiển thị danh sách nông sản và số lượng
                    let tableRows = '';
                    if(productsList.length > 0) {
                        productsList.forEach((p, i) => {
                            tableRows += `
                                <tr>
                                    <td style="text-align: left; padding: 8px; border-bottom: 1px solid #ddd;">${i + 1}. <b>${p.ten}</b></td>
                                    <td style="text-align: right; padding: 8px; border-bottom: 1px solid #ddd;" class="text-success fw-bold">${p.soluong} ${p.dvt}</td>
                                </tr>`;
                        });
                    } else {
                        tableRows = `<tr><td colspan="2" style="padding: 8px; text-align: center; color: #888;">Không có dữ liệu chi tiết</td></tr>`;
                    }

                    // Nội dung HTML sẽ chèn vào ruột của Pop-up
                    const popupContent = `
                        <div style="font-size: 14px; color: #333;">
                            <p style="text-align: left; margin-bottom: 12px;">Xem trước thông tin đơn hàng trước khi phê duyệt:</p>
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px; background: #f9f9f9; border-radius: 6px; overflow: hidden;">
                                <thead style="background: #e9ecef;">
                                    <tr>
                                        <th style="text-align: left; padding: 8px;">Tên nông sản</th>
                                        <th style="text-align: right; padding: 8px;">Số lượng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${tableRows}
                                </tbody>
                            </table>
                            <div style="display: flex; justify-content: space-between; font-size: 16px; font-weight: bold; padding-top: 5px; border-top: 2px dashed #ccc;">
                                <span>TỔNG TIỀN THANH TOÁN:</span>
                                <span style="color: #dc3545;">${tongTien} VNĐ</span>
                            </div>
                        </div>
                    `;

                    // Hiển thị Pop-up xác nhận chứa thông tin trực quan
                    Swal.fire({
                        title: `XÁC NHẬN DUYỆT ĐƠN HÀNG #${donHangId}`,
                        html: popupContent,
                        icon: 'info',
                        showCancelButton: true,
                        confirmButtonColor: '#198754', // Nút duyệt màu xanh
                        cancelButtonColor: '#6c757d',  // Nút hủy màu xám
                        confirmButtonText: '<i class="bi bi-check2-circle"></i> Phê duyệt & Trừ kho',
                        cancelButtonText: 'Đóng lại',
                        allowOutsideClick: false,
                        width: '500px'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // Mở trạng thái loading trong khi gửi Ajax
                            Swal.fire({
                                title: 'Đang tiến hành duyệt...',
                                text: 'Vui lòng chờ hệ thống xử lý kho.',
                                allowOutsideClick: false,
                                didOpen: () => { Swal.showLoading(); }
                            });

                            // Gửi yêu cầu ngầm lên DonHangController
                            fetch(`/Admin/DonHang/DuyetDonHang/${donHangId}`, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                                }
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire({
                                        title: 'Duyệt thành công!',
                                        text: data.message || 'Đơn hàng đã được xử lý hoàn tất.',
                                        icon: 'success',
                                        confirmButtonText: 'OK'
                                    }).then(() => {
                                        location.reload(); // Làm mới trang để cập nhật giao diện bảng
                                    });
                                } else {
                                    Swal.fire({
                                        title: 'Duyệt thất bại!',
                                        text: data.message || 'Số lượng trong kho không đủ đáp ứng.',
                                        icon: 'error',
                                        confirmButtonText: 'Đóng'
                                    });
                                }
                            })
                            .catch(error => {
                                console.error('Lỗi kết nối máy chủ:', error);
                                Swal.fire({
                                    title: 'Lỗi hệ thống!',
                                    text: 'Không thể kết nối đến máy chủ.',
                                    icon: 'error',
                                    confirmButtonText: 'Đóng'
                                });
                            });
                        }
                    });
                });
            });
        });
    </script>
}