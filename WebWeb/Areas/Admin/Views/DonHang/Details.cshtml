@model WebWeb.Models.DonHangLe
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng Lẻ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="mb-3">
    <a asp-action="Index" class="text-success text-decoration-none small fw-medium">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách đơn hàng lẻ
    </a>
</div>

<div class="admin-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">Chi tiết đơn hàng #DHL-@Model.DonHangLeId</h4>
            <p class="text-muted small mb-0">Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div>
            <span class="badge bg-light text-dark border p-2">
                <i class="bi bi-clock"></i> Khung giờ: @Model.KhungGioGiaoHang
            </span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="p-3 border rounded-3 bg-light-subtle h-100">
                <h6 class="fw-bold text-success mb-3"><i class="bi bi-person-bounding-box"></i> Thông tin giao hàng</h6>
                <p class="mb-1"><strong>Người nhận:</strong> @(Model.KhachHang?.HoTen ?? Model.NameCusNonAccount )</p>
                <p class="mb-1"><strong>Số điện thoại:</strong> @(Model.KhachHang?.SoDienThoai ?? Model.PhoneNonAccount )</p>
                <p class="mb-0"><strong>Địa chỉ:</strong> @(Model.DiaChi?.DiaChiGiao ?? Model.AddressNonAccount )</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="p-3 border rounded-3 bg-light-subtle h-100">
                <h6 class="fw-bold text-success mb-3"><i class="bi bi-shield-check"></i> Trạng thái & Vận chuyển</h6>
                <div class="mb-2">
                    <strong>Thanh toán:</strong> 
                    @if (Model.TrangThaiThanhToan == "Đã thanh toán")
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                    }
                    <small class="text-muted d-block mt-1">Hình thức: @Model.PhuongThucThanhToan</small>
                </div>
                <div>
                    <strong>Trạng thái đơn:</strong> <span class="text-dark fw-semibold">@Model.TrangThaiDonHang</span>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold text-dark mb-3">Danh mục nông sản đóng gói</h5>
    <div class="table-responsive border rounded-3 mb-4">
        <table class="table table-hover align-middle mb-0" style="font-size: 14.5px;">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Nông Sản</th>
                    <th class="text-center">Số Lượng Đặt</th>
                    <th class="text-end">Đơn Giá</th>
                    <th class="text-center">Trọng Lượng Thực Tế</th>
                    <th class="text-end pe-3">Thành Tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ct in Model.ChiTietDonHangLes)
                {
                    <tr>
                        <td class="ps-3 fw-semibold text-dark">@ct.NongSan?.TenNongSan</td>
                        <td class="text-center">@ct.SoLuongDat bó/gói</td>
                        <td class="text-end">@ct.DonGiaThoiDiem.ToString("#,##0") đ</td>
                        <td class="text-center text-primary fw-medium">
                            @(ct.TrongLuongThucTe.HasValue ? ct.TrongLuongThucTe.Value.ToString("0.##") + " kg" : "Chờ cân thực tế")
                        </td>
                        <td class="text-end fw-bold text-dark pe-3">
                            @((ct.ThanhTienThucTe ?? (ct.SoLuongDat * ct.DonGiaThoiDiem)).ToString("#,##0")) đ
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row justify-content-end">
        <div class="col-md-4">
            <div class="border rounded-3 p-3 bg-light">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính:</span>
                    <span class="fw-medium">@Model.TongTienTamTinh.ToString("#,##0") đ</span>
                </div>
                @if (Model.TienChenhLech.HasValue && Model.TienChenhLech.Value != 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Chênh lệch (Cân thực tế):</span>
                        <span class="@(Model.TienChenhLech > 0 ? "text-danger" : "text-success") fw-medium">
                            @(Model.TienChenhLech > 0 ? "+" : "")@Model.TienChenhLech.Value.ToString("#,##0") đ
                        </span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold text-dark">Tổng tiền thực tế:</span>
                    <span class="fs-5 fw-bold text-success">@((Model.TongTienThucTe ?? Model.TongTienTamTinh).ToString("#,##0")) đ</span>
                </div>
            </div>
        </div>
    </div>
</div>