@using WebWeb.Models
@model WebWeb.Models.DonHangLe
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng Lẻ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="mb-3">
    <a asp-action="Index" class="text-success text-decoration-none small fw-medium">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách đơn hàng lẻ
    </a>
</div>

<div class="admin-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">Chi tiết đơn hàng #DHL-@Model.DonHangLeId</h4>
            <p class="text-muted small mb-0">Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-light text-dark border p-2">
                <i class="bi bi-clock"></i> Khung giờ: @Model.KhungGioGiaoHang
            </span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="p-3 border rounded-3 bg-light-subtle h-100">
                <h6 class="fw-bold text-success mb-3"><i class="bi bi-person-bounding-box"></i> Thông tin giao hàng</h6>
                <p class="mb-1"><strong>Người nhận:</strong> @(Model.KhachHang?.HoTen ?? Model.NameCusNonAccount )</p>
                <p class="mb-1"><strong>Số điện thoại:</strong> @(Model.KhachHang?.SoDienThoai ?? Model.PhoneNonAccount )</p>
                <p class="mb-0"><strong>Địa chỉ:</strong> @(Model.DiaChi?.DiaChiGiao ?? Model.AddressNonAccount )</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="p-3 border rounded-3 bg-light-subtle h-100">
                <h6 class="fw-bold text-success mb-3"><i class="bi bi-shield-check"></i> Trạng thái & Vận chuyển</h6>
                <div class="mb-2">
                    <strong>Thanh toán:</strong> 
                    @if (Model.TrangThaiThanhToan == OrderStatuses.DaThanhToan)
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                    }
                    <small class="text-muted d-block mt-1">Hình thức: @Model.PhuongThucThanhToan</small>
                </div>
                <div>
                    <strong>Trạng thái đơn:</strong> <span class="text-dark fw-semibold">@Model.TrangThaiDonHang</span>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold text-dark mb-3">Danh mục nông sản đóng gói</h5>
    <div class="table-responsive border rounded-3 mb-4">
        <table class="table table-hover align-middle mb-0" style="font-size: 14.5px;">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Nông Sản</th>
                    <th class="text-center">Số Lượng Đặt</th>
                    <th class="text-end">Đơn Giá</th>
                    <th class="text-end pe-3">Thành Tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ct in Model.ChiTietDonHangLes)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@Url.Content("~/images/" + ct.NongSan?.HinhAnh)" class="rounded-2" style="width: 50px; height: 50px; object-fit: cover;" alt="">
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">@ct.NongSan?.TenNongSan</h6>
                                    <small class="text-muted">Đơn vị: @ct.NongSan?.DonViTinh</small>
                                </div>
                            </div>
                        </td>
                        <td class="text-center fw-medium">@ct.SoLuongDat</td>
                        
                        <td class="text-end fw-medium">@ct.DonGiaThoiDiem.ToString("#,##0") đ</td>
                        
                        <td class="text-end fw-bold text-dark">
                            @((ct.SoLuongDat * ct.DonGiaThoiDiem).ToString("#,##0")) đ
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row justify-content-end">
        <div class="col-md-4">
            <div class="border rounded-3 p-3 bg-light">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính:</span>
                    <span class="fw-medium">@Model.TongTienTamTinh.ToString("#,##0") đ</span>
                </div>
                @if (Model.TienChenhLech.HasValue && Model.TienChenhLech.Value != 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Chênh lệch (Cân thực tế):</span>
                        <span class="@(Model.TienChenhLech > 0 ? "text-danger" : "text-success") fw-medium">
                            @(Model.TienChenhLech > 0 ? "+" : "")@Model.TienChenhLech.Value.ToString("#,##0") đ
                        </span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold text-dark">Tổng tiền thực tế:</span>
                    <span class="fs-5 fw-bold text-success">@((Model.TongTienThucTe ?? Model.TongTienTamTinh).ToString("#,##0")) đ</span>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-start align-items-center gap-2">
            @if (Model.TrangThaiDonHang == WebWeb.Models.OrderStatuses.ChoDuyet) {
                // Chuẩn bị dữ liệu danh sách sản phẩm để truyền vào HTML attribute
                var dsSanPham = Model.ChiTietDonHangLes?.Select(ct => new {
                    ten = ct.NongSan?.TenNongSan ?? "Nông sản",
                    soluong = ct.SoLuongDat,
                    dvt = ct.NongSan?.DonViTinh ?? "kg"
                }).ToList();
                                            
                var jsonSanPham = System.Text.Json.JsonSerializer.Serialize(dsSanPham);

                <button type="button" class="btn btn-success btn-duyet-don fw-bold px-3 d-flex align-items-center gap-1 shadow-sm" 
                data-id="@Model.DonHangLeId"
                data-total="@Model.TongTienTamTinh.ToString("#,##0")"
                data-products='@jsonSanPham'>
                    <i class="bi bi-check-circle-fill"></i> Duyệt đơn hàng này
                </button>
            }
        </div>
    </div>
</div>

<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const duyetButtons = document.querySelectorAll('.btn-duyet-don');

            duyetButtons.forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault();
                    
                    const donHangId = this.getAttribute('data-id');
                    const tongTien = this.getAttribute('data-total');
                    
                    // Bốc và giải mã chuỗi danh sách sản phẩm
                    const rawProducts = this.getAttribute('data-products');
                    let productsList = [];
                    try {
                        productsList = JSON.parse(rawProducts) || [];
                    } catch (err) {
                        console.error("Lỗi đọc dữ liệu sản phẩm:", err);
                    }

                    // Dựng bảng HTML hiển thị danh sách nông sản và số lượng
                    let tableRows = '';
                    if(productsList.length > 0) {
                        productsList.forEach((p, i) => {
                            tableRows += `
                                <tr>
                                    <td style="text-align: left; padding: 8px; border-bottom: 1px solid #ddd;">${i + 1}. <b>${p.ten}</b></td>
                                    <td style="text-align: right; padding: 8px; border-bottom: 1px solid #ddd;" class="text-success fw-bold">${p.soluong} ${p.dvt}</td>
                                </tr>`;
                        });
                    } else {
                        tableRows = `<tr><td colspan="2" style="padding: 8px; text-align: center; color: #888;">Không có dữ liệu chi tiết</td></tr>`;
                    }

                    // Nội dung HTML sẽ chèn vào ruột của Pop-up
                    const popupContent = `
                        <div style="font-size: 14px; color: #333;">
                            <p style="text-align: left; margin-bottom: 12px;">Xem trước thông tin đơn hàng trước khi phê duyệt:</p>
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px; background: #f9f9f9; border-radius: 6px; overflow: hidden;">
                                <thead style="background: #e9ecef;">
                                    <tr>
                                        <th style="text-align: left; padding: 8px;">Tên nông sản</th>
                                        <th style="text-align: right; padding: 8px;">Số lượng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${tableRows}
                                </tbody>
                            </table>
                            <div style="display: flex; justify-content: space-between; font-size: 16px; font-weight: bold; padding-top: 5px; border-top: 2px dashed #ccc;">
                                <span>TỔNG TIỀN THANH TOÁN:</span>
                                <span style="color: #dc3545;">${tongTien} VNĐ</span>
                            </div>
                        </div>
                    `;

                    // Hiển thị Pop-up xác nhận chứa thông tin trực quan
                    Swal.fire({
                        title: `XÁC NHẬN DUYỆT ĐƠN HÀNG #${donHangId}`,
                        html: popupContent,
                        icon: 'info',
                        showCancelButton: true,
                        confirmButtonColor: '#198754', // Nút duyệt màu xanh
                        cancelButtonColor: '#6c757d',  // Nút hủy màu xám
                        confirmButtonText: '<i class="bi bi-check2-circle"></i> Phê duyệt & Trừ kho',
                        cancelButtonText: 'Đóng lại',
                        allowOutsideClick: false,
                        width: '500px'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // Mở trạng thái loading trong khi gửi Ajax
                            Swal.fire({
                                title: 'Đang tiến hành duyệt...',
                                text: 'Vui lòng chờ hệ thống xử lý kho.',
                                allowOutsideClick: false,
                                didOpen: () => { Swal.showLoading(); }
                            });

                            // Gửi yêu cầu ngầm lên DonHangController
                            fetch(`/Admin/DonHang/DuyetDonHang/${donHangId}`, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                                }
                            })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire({
                                        title: 'Duyệt thành công!',
                                        text: data.message || 'Đơn hàng đã được xử lý hoàn tất.',
                                        icon: 'success',
                                        confirmButtonText: 'OK'
                                    }).then(() => {
                                        location.reload(); // Làm mới trang để cập nhật giao diện bảng
                                    });
                                } else {
                                    Swal.fire({
                                        title: 'Duyệt thất bại!',
                                        text: data.message || 'Số lượng trong kho không đủ đáp ứng.',
                                        icon: 'error',
                                        confirmButtonText: 'Đóng'
                                    });
                                }
                            })
                            .catch(error => {
                                console.error('Lỗi kết nối máy chủ:', error);
                                Swal.fire({
                                    title: 'Lỗi hệ thống!',
                                    text: 'Không thể kết nối đến máy chủ.',
                                    icon: 'error',
                                    confirmButtonText: 'Đóng'
                                });
                            });
                        }
                    });
                });
            });
        });
    </script>
}