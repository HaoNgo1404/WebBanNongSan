@model IEnumerable<WebWeb.Models.NhanVien>
@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Quản lý nhân viên hệ thống</h3>
            <p class="text-muted small mb-0">Xem danh sách tài khoản nhân viên, vai trò phân quyền và trạng thái hoạt động.</p>
        </div>
        <a asp-action="Create" class="btn btn-success fw-bold px-3 rounded-3 shadow-sm d-flex align-items-center gap-1">
            <i class="bi bi-person-plus-fill"></i> Thêm nhân viên mới
        </a>
    </div>

    <div class="admin-card p-4">
        <div class="table-responsive">
            <div class="nhanvien-container" style="max-height: 380px; overflow-y: auto; padding-right: 8px;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th class="ps-3">Mã NV</th>
                            <th>Họ và tên</th>
                            <th>Email liên hệ</th>
                            <th>Vai trò / Chức vụ</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-end pe-3">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.NhanVienId">
                                <td class="ps-3 fw-bold text-secondary">#NV-@item.NhanVienId</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-success-subtle text-success rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 35px; height: 35px;">
                                            @item.HoTen.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-semibold text-dark">@item.HoTen</span>
                                    </div>
                                </td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-2.5 py-1 rounded-pill fw-medium">
                                        <i class="bi bi-shield-lock-fill me-1"></i> @item.VaiTro?.TenVaiTro
                                    </span>
                                </td>
                                <td class="text-center" id="status-@item.NhanVienId">
                                    @if (item.TrangThai == true)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded-3">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-3">Ngừng hoạt động</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="Details" asp-route-id="@item.NhanVienId" class="btn btn-outline-info btn-sm rounded-3">
                                            <i class="bi bi-eye-fill"></i> Xem
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.NhanVienId" class="btn btn-outline-primary btn-sm rounded-3">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.NhanVienId" class="btn btn-outline-danger btn-sm rounded-3">
                                            <i class="bi bi-trash3-fill"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Form ẩn xử lý gửi Token bảo mật -->
<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        function deleteEmployee(empId, empName) {
            if (confirm(`Hào có chắc muốn xóa tài khoản của nhân viên "${empName}" không?`)) {
                const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;

                const formData = new FormData();
                formData.append('id', empId);
                formData.append('__RequestVerificationToken', token);

                fetch(`@Url.Action("Delete", "Employee")`, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.json())
                .then(data => {
                    alert(data.message);
                    if (data.success) {
                        if (data.message.includes("Ngừng hoạt động")) {
                            // Nếu chuyển trạng thái chứ không xóa hẳn (do vướng khóa ngoại)
                            const statusCell = document.getElementById(`status-${empId}`);
                            if (statusCell) {
                                statusCell.innerHTML = '<span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded-3">Ngừng hoạt động</span>';
                            }
                        } else {
                            // Xóa hẳn dòng đó khỏi giao diện dữ liệu
                            const row = document.getElementById(`row-${empId}`);
                            if (row) row.remove();
                        }
                    }
                })
                .catch(err => alert("Lỗi hệ thống khi thực hiện xóa nhân viên!"));
            }
        }
    </script>
}