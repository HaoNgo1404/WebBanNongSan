@model WebWeb.Models.NhanVien
@{
    ViewData["Title"] = "Sửa Nhân Viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="mb-3">
    <a asp-action="Index" class="text-success text-decoration-none small fw-medium">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách nhân viên
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="admin-card p-4">
            <div class="border-bottom pb-3 mb-4">
                <h4 class="fw-bold text-dark mb-1"><i class="bi bi-pencil-square text-primary me-1"></i> Chỉnh sửa nhân viên #NV-@Model.NhanVienId</h4>
                <p class="text-muted small mb-0">Cập nhật hồ sơ, điều chỉnh vai trò phòng ban hoặc trạng thái hoạt động.</p>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="NhanVienId" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="HoTen" class="form-label fw-semibold text-dark small">Họ và tên nhân viên <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-person"></i></span>
                            <input asp-for="HoTen" class="form-control" required />
                        </div>
                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold text-dark small">Email liên hệ <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" type="email" class="form-control" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-dark small">Mật khẩu mới (Để trống nếu giữ nguyên)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-key"></i></span>
                            <input asp-for="MatKhau" type="password" class="form-control" placeholder="Nhập mật khẩu mới nếu muốn đổi" value="" />
                        </div>
                        <span asp-validation-for="MatKhau" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="VaiTroId" class="form-label fw-semibold text-dark small">Vai trò phân quyền <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-shield-lock"></i></span>
                            <select asp-for="VaiTroId" class="form-select" asp-items="ViewBag.VaiTroId" required></select>
                        </div>
                        <span asp-validation-for="VaiTroId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="p-3 bg-light rounded-3 mb-4 d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="fw-bold text-dark mb-0 small">Trạng thái hoạt động tài khoản</h6>
                        <small class="text-muted" style="font-size: 12px;">Nếu tắt, nhân viên sẽ không thể đăng nhập vào cổng Admin Portal.</small>
                    </div>
                    <div class="form-check form-switch fs-5 mb-0">
                        <!-- Ép kiểm tra giá trị null để gán đúng true/false cho switch-input -->
                        <input class="form-check-input" type="checkbox" role="switch" id="switchTrangThai" name="TrangThai" value="true" @(Model.TrangThai == true ? "checked" : "") />
                        <input type="hidden" name="TrangThai" value="false" />
                    </div>
                </div>

                <div class="border-top pt-3 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light rounded-3 fw-semibold px-4 border">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary rounded-3 fw-bold px-4">
                        <i class="bi bi-check-lg"></i> Cập nhật ngay
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>