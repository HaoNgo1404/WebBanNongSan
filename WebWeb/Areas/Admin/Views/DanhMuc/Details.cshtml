@model WebWeb.Models.DanhMuc
@{
    ViewData["Title"] = "Chi tiết Danh mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Chi tiết danh mục</h2>
            <p class="text-muted mb-0">Cấu trúc thông tin phân loại chi tiết.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="DanhMuc" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
            <a class="btn btn-success admin-btn" asp-area="Admin" asp-controller="DanhMuc" asp-action="Edit" asp-route-id="@Model.DanhMucId"><i class="bi bi-pencil"></i> Chỉnh sửa</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-panel p-4">
                <h5 class="fw-semibold mb-3 text-success"><i class="bi bi-tag me-2"></i>Thông tin danh mục</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted mb-1">Tên danh mục</label>
                        <div class="p-2 border rounded bg-light fw-semibold text-dark">@Model.TenDanhMuc</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted mb-1">Loại ngành hàng</label>
                        <div class="p-2 border rounded bg-light">@Model.LoaiHang</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted mb-1">Mô tả chi tiết</label>
                        <div class="p-3 border rounded bg-light" style="white-space: pre-line;">
                            @(string.IsNullOrWhiteSpace(Model.MoTa) ? "Không có dữ liệu mô tả cho danh mục này." : Model.MoTa)
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="admin-panel p-4">
                <h5 class="fw-semibold mb-3 text-secondary"><i class="bi bi-info-square me-2"></i>Hệ thống</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2 py-2 border-bottom"><strong>Mã danh mục:</strong> <span class="badge bg-dark float-end">#DM-@Model.DanhMucId</span></li>
                    <li class="py-2"><strong>Phạm vi áp dụng:</strong> <span class="badge bg-success float-end">Toàn hệ thống nông sản</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>