@model WebWeb.Models.DanhMuc
@{
    ViewData["Title"] = "Xóa Danh mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Xác nhận xóa danh mục</h2>
            <p class="text-muted mb-0">Cân nhắc kỹ trước khi gỡ bỏ phân loại danh mục này.</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="DanhMuc" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-empty-state text-center py-5 border rounded bg-white shadow-sm">
        <div class="mb-3 text-danger"><i class="bi bi-exclamation-octagon" style="font-size: 3.5rem;"></i></div>
        <h4 class="fw-bold text-dark mb-2">Bạn có chắc chắn muốn xóa danh mục này?</h4>
        <p class="text-muted mb-4">Hệ thống sẽ thực hiện xóa danh mục <strong class="text-danger">@Model.TenDanhMuc</strong> (#DM-@Model.DanhMucId) khỏi cơ sở dữ liệu.</p>
        
        <form asp-area="Admin" asp-controller="DanhMuc" asp-action="Delete" method="post" class="d-inline-block">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DanhMucId" name="id" />
            <div class="d-flex gap-2 justify-content-center">
                <button type="submit" class="btn btn-danger admin-btn px-4"><i class="bi bi-trash-fill me-1"></i> Đồng ý xóa</button>
                <a class="btn btn-outline-secondary admin-btn px-4" asp-area="Admin" asp-controller="DanhMuc" asp-action="Index">Hủy hành động</a>
            </div>
        </form>
    </div>
</div>