@model WebWeb.Models.DanhMuc
@{
    ViewData["Title"] = "Chỉnh sửa Danh mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Chỉnh sửa danh mục</h2>
            <p class="text-muted mb-0">Cập nhật thông tin phân loại cho danh mục #DM-@Model.DanhMucId</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="DanhMuc" asp-action="Index"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-form-panel">
        <form asp-area="Admin" asp-controller="DanhMuc" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DanhMucId" />

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tên danh mục</label>
                    <input asp-for="TenDanhMuc" class="form-control" required />
                    <span asp-validation-for="TenDanhMuc" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Loại hàng</label>
                    <input asp-for="LoaiHang" class="form-control" required />
                    <span asp-validation-for="LoaiHang" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Mô tả danh mục</label>
                    <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="MoTa" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-success admin-btn px-4" type="submit"><i class="bi bi-check-circle me-1"></i> Cập nhật thay đổi</button>
                <a class="btn btn-outline-secondary admin-btn" asp-area="Admin" asp-controller="DanhMuc" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</div>