@model IEnumerable<WebWeb.Models.KhieuNai>
@{
    ViewData["Title"] = "Quản Lý Khiếu Nại Đơn Hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="admin-card p-4">
    <!-- THANH MENU TAB ĐỒNG BỘ -->
    <div class="d-flex border-bottom mb-4">
        <a class="nav-link text-muted pb-2 pe-3 text-decoration-none" 
           asp-area="Admin" asp-controller="DanhGia" asp-action="Index">Đánh giá sản phẩm</a>
        <a class="nav-link text-muted pb-2 px-3 text-decoration-none" 
           asp-area="Admin" asp-controller="DanhGia" asp-action="IndexDonHang">Đánh giá đơn hàng</a>
        <a class="nav-link active fw-bold text-success border-bottom border-2 border-success pb-2 ps-3 text-decoration-none" 
           asp-area="Admin" asp-controller="DanhGia" asp-action="IndexKhieuNai">Khiếu nại đơn hàng</a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Danh sách khiếu nại lỗi đơn hàng</h3>
            <p class="text-muted mb-0">Tiếp nhận báo lỗi, xử lý phương án bồi thường tài chính và xử lý tranh chấp cho khách hàng.</p>
        </div>
    </div>

    <!-- KHỐI BẢNG DỮ LIỆU ĐỒNG BỘ CSS -->
    <div class="admin-panel p-4">
        <div class="table-responsive">
            <div class="khieunai-container" style="max-height: 380px; overflow-y: auto; padding-right: 8px;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Mã Khiếu Nại</th>
                            <th>Khách Hàng</th>
                            <th>Mã Đơn Lẻ</th>
                            <th>Nội Dung Khiếu Nại</th>
                            <th>Ngày Nhận Đơn</th>
                            <th class="text-center">Trạng Thái</th>
                            <th class="text-nowrap text-end pe-3">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">#KN-@item.KhieuNaiId</td>
                                    <td>@(item.KhachHang?.HoTen ?? "Chưa rõ danh tính")</td>
                                    <td class="fw-bold text-secondary">#DHL-@item.DonHangLeId</td>
                                    <td class="small text-truncate" style="max-width: 250px;">@item.NoiDung</td>
                                    <td>@item.NgayGui.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        @if (item.TrangThai == 0)
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">Chưa xử lý</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Đã giải quyết</span>
                                        }
                                    </td>
                                    <td class="text-nowrap text-end pe-3">
                                        <a asp-area="Admin" asp-controller="DanhGia" asp-action="XuLyKhieuNai" asp-route-id="@item.KhieuNaiId" class="btn btn-sm btn-outline-danger rounded-2 px-3">
                                            <i class="bi bi-wrench-adjustable"></i> Xử lý đơn
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">Tuyệt vời, hệ thống hiện không ghi nhận đơn khiếu nại nào!</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>