@model WebWeb.Models.LoHang
@{
    ViewData["Title"] = "Hồ Sơ Chi Tiết Lô Hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Chi tiết lô hàng #LH-@Model.LoHangId</h3>
            <p class="text-muted mb-0">Thông tin toàn diện về nguồn hàng hữu cơ nhập kho và chứng từ đi kèm.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="LoHangList"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="p-4 border rounded bg-white shadow-sm mb-4">
                <h5 class="text-success fw-bold mb-3"><i class="bi bi-info-circle-fill me-2"></i>Dữ liệu luồng hàng</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted d-block mb-1">Tên nông sản</label>
                        <div class="p-2 bg-light border rounded fw-bold text-dark">@(Model.NongSan?.TenNongSan ?? "Không rõ")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted d-block mb-1">Nhà cung cấp (Nhà vườn)</label>
                        <div class="p-2 bg-light border rounded">@(Model.PhieuNhapKho?.NhaVuon?.TenNhaVuon ?? "Không rõ")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted d-block mb-1">Số lượng nhập ban đầu</label>
                        <div class="p-2 bg-light border rounded">@Model.SoLuongNhap</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted d-block mb-1">Lượng tồn kho thực tế hiện hành</label>
                        <div class="p-2 bg-info bg-opacity-10 border border-info rounded fw-bold text-primary">@Model.SoLuongTon</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted d-block mb-1">Đơn giá nhập</label>
                        <div class="p-2 bg-light border rounded text-success fw-semibold">@Model.DonGiaNhap.ToString("#,##0") đ</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted d-block mb-1">Trạng thái hạn dùng</label>
                        <div class="p-2 bg-light border rounded">@Model.TrangThaiHsd</div>
                    </div>
                </div>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm">
                <h5 class="text-primary fw-bold mb-3"><i class="bi bi-file-earmark-text-fill me-2"></i>Thông tin Chứng từ gốc (Phiếu Nhập)</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="text-muted d-block mb-1">Mã số chứng từ</label>
                        <div class="p-2 bg-light border rounded fw-bold">#PN-@Model.PhieuNhapId</div>
                    </div>
                    <div class="col-md-4">
                        <label class="text-muted d-block mb-1">Nhân viên lập phiếu</label>
                        <div class="p-2 bg-light border rounded">@(Model.PhieuNhapKho?.NhanVien?.HoTen ?? "Hệ thống")</div>
                    </div>
                    <div class="col-md-4">
                        <label class="text-muted d-block mb-1">Tổng tiền hóa đơn nhập</label>
                        <div class="p-2 bg-light border rounded fw-semibold text-danger">@(Model.PhieuNhapKho?.TongTienNhap.ToString("#,##0") ?? "0") đ</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="p-4 border rounded bg-white shadow-sm h-100">
                <h5 class="text-dark fw-bold mb-4"><i class="bi bi-calendar3 me-2"></i>Mốc thời gian</h5>
                <div class="mb-4 border-start border-2 border-success ps-3">
                    <small class="text-muted d-block">Ngày thu hoạch tại vườn</small>
                    <span class="fw-semibold">@(Model.NgayThuHoach?.ToString("dd/MM/yyyy") ?? "Không ghi nhận")</span>
                </div>
                <div class="mb-4 border-start border-2 border-primary ps-3">
                    <small class="text-muted d-block">Thời điểm cập bến nhập kho</small>
                    <span class="fw-semibold">@Model.NgayNhapKho.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="mb-4 border-start border-2 border-danger ps-3">
                    <small class="text-muted d-block">Ngày hết hạn sử dụng</small>
                    <span class="fw-semibold text-danger">@Model.HanSuDung.ToString("dd/MM/yyyy")</span>
                </div>
            </div>
        </div>
    </div>
</div>