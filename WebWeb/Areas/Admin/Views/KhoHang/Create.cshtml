@{
    ViewData["Title"] = "Thêm mới Kho hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="h3 fw-bold mb-1">Thêm mới kho hàng</h2>
            <p class="text-muted mb-0">Form mẫu dùng chung cho module kho hàng.</p>
        </div>
        <a class="btn btn-outline-secondary admin-btn" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="admin-form-panel">
        <form>
            <div class="admin-form-grid">
                <div class="mb-3">
                    <label class="form-label">Tên kho hàng</label>
                    <input class="form-control" placeholder="Nhập tên..." />
                </div>
                <div class="mb-3">
                    <label class="form-label">Trạng thái</label>
                    <select class="form-select">
                        <option>Hoạt động</option>
                        <option>Ẩn</option>
                        <option>Chờ duyệt</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea class="form-control" rows="4" placeholder="Thông tin bổ sung..."></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Ngày tạo</label>
                    <input class="form-control" type="date" />
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-success admin-btn" type="button">Lưu</button>
                <a class="btn btn-outline-secondary admin-btn" href="@Url.Action("Index")">Hủy</a>
            </div>
        </form>
    </div>
</div>
