@model IEnumerable<WebWeb.Models.LoHang>
@{
    ViewData["Title"] = "Chi tiết các lô hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid px-4 py-3">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-link text-success p-0 fw-bold text-decoration-none">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách tồn kho
        </a>
    </div>

    <div class="admin-card p-4 bg-white rounded-3 shadow-sm">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1"><i class="bi bi-boxes text-success"></i> Danh sách phân rã lô hàng</h3>
                <p class="text-muted mb-0">Nông sản: <strong class="text-success fs-5">@ViewBag.TenNongSan</strong></p>
            </div>
            <div>
                <!-- Dự phòng nút bấm lập báo cáo hao hụt nhanh cho sản phẩm này luôn -->
                <a asp-action="CreateBaoCao" asp-route-nongSanId="@ViewBag.NongSanId" class="btn btn-outline-danger btn-sm rounded-2">
                    <i class="bi bi-exclamation-octagon"></i> Báo cáo hao hụt nhanh
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle bg-white rounded">
                <thead class="table-light">
                    <tr>
                        <th>Mã Lô Hàng</th>
                        <th>Nhà Vườn Cung Cấp</th>
                        <th>Ngày Nhập Kho</th>
                        <th>Hạn Sử Dụng</th>
                        <th>Đơn Giá Nhập</th>
                        <th>SL Nhập Đầu</th>
                        <th>SL Tồn Hiện Tại</th>
                        <th>Trạng Thái HSD</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.SoLuongTon == 0 ? "table-light text-muted" : "")">
                            <td class="fw-bold">#LO-@item.LoHangId</td>
                            <td>@(item.PhieuNhapKho?.NhaVuon?.TenNhaVuon ?? "Không rõ")</td>
                            <td>@item.NgayNhapKho.ToString("dd/MM/yyyy")</td>
                            <td>@item.HanSuDung.ToString("dd/MM/yyyy")</td>
                            <td class="text-success fw-semibold">@item.DonGiaNhap.ToString("#,##0") đ</td>
                            <td>@item.SoLuongNhap</td>
                            <td>
                                @if (item.SoLuongTon == 0) { 
                                    <span class="badge bg-secondary">Hết hàng</span> 
                                } else { 
                                    <span class="badge bg-info text-dark fw-bold">@item.SoLuongTon</span> 
                                }
                            </td>
                            <td>
                                @if (item.SoLuongTon == 0)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-dash-circle"></i> Hết hàng</span>
                                }
                                else if (item.HanSuDung.Date < DateTime.Now.Date)
                                {
                                    <span class="badge bg-danger-subtle text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Hết hạn</span>
                                }
                                else if ((item.HanSuDung.Date - DateTime.Now.Date).TotalDays <= 3)
                                {
                                    <span class="badge bg-warning-subtle text-warning"><i class="bi bi-clock-history"></i> Sắp hết hạn</span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle"></i> Còn hạn</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a class="btn btn-outline-secondary btn-sm rounded-2" asp-action="EditTonKho" asp-route-id="@item.LoHangId"><i class="bi bi-pencil"></i> Sửa</a>
                                    <a class="btn btn-outline-danger btn-sm rounded-2" asp-action="DeleteTonKho" asp-route-id="@item.LoHangId"><i class="bi bi-trash"></i> Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>