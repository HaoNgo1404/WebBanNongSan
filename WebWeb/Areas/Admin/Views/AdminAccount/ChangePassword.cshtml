@model WebWeb.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi Mật Khẩu";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="admin-card p-4">
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">Bảo mật tài khoản</h3>
        <p class="text-muted mb-0">Thay đổi định kỳ mật khẩu quản trị để nâng cao tính an toàn bảo mật hệ thống.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show p-3 mb-4" role="alert">
            <i class="bi bi-shield-check-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-xl-6 col-lg-8">
            <div class="p-4 border rounded bg-white shadow-sm">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="bi bi-key-fill me-2 text-warning"></i>Thiết lập mật khẩu mới</h5>
                
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu hiện tại</label>
                        <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu đang dùng" required />
                        <span asp-validation-for="OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu mới</label>
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" required />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-shield-lock me-1"></i> Cập nhật mật khẩu</button>
                        <a class="btn btn-outline-secondary px-4" asp-action="Index">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>