@model WebWeb.Models.ThamSo
@{
    ViewData["Title"] = "Điều chỉnh tham số";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4" style="max-width: 700px;">
    <div class="card shadow border-0 rounded-3">
        <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Cập nhật giá trị cấu hình</h5>
        </div>
        <div class="card-body p-4">
            <form asp-area="Admin" asp-controller="ThamSo" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Mã định danh tham số (Bất biến)</label>
                    <input type="text" name="id" value="@Model.MaThamSo" class="form-control bg-light fw-mono text-danger" readonly />
                </div>

                <div class="mb-3">
                    <label for="giaTri" class="form-label fw-bold text-success">Giá trị cấu hình mới (Số thập phân / Số nguyên)</label>
                    <input type="number" id="giaTri" name="giaTri" value="@Model.GiaTri" step="any" class="form-control form-control-lg text-success fw-bold" placeholder="Nhập số tiền hoặc tỷ lệ phần trăm..." required />
                    <div class="form-text text-muted">Lưu ý: Nhập số tiền cụ thể (ví dụ: 30000) hoặc số thập phân tỉ lệ tích điểm (ví dụ: 0.02).</div>
                </div>

                <div class="mb-4">
                    <label for="ghiChu" class="form-label fw-bold text-secondary">Mô tả / Ghi chú hướng dẫn áp dụng</label>
                    <textarea id="ghiChu" name="ghiChu" rows="3" class="form-control" placeholder="Viết mô tả để các Admin khác hiểu tham số này dùng làm gì..." required>@Model.GhiChu</textarea>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                    <a asp-area="Admin" asp-controller="ThamSo" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-success px-5 fw-bold">
                        <i class="bi bi-save-fill me-1"></i> Xác nhận Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>