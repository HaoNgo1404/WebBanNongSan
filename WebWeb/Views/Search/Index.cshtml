@model IEnumerable<WebWeb.Models.NongSan>
@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />

<div class="container py-5 order-shell">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Tìm kiếm</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-3">
            <form asp-controller="Search" asp-action="Index" method="get" class="order-card shadow-sm p-3">
                <h5 class="fw-semibold mb-3 text-success"><i class="bi bi-funnel-fill"></i> Bộ lọc sản phẩm</h5>
                
                <input type="hidden" name="keyword" value="@ViewBag.Keyword" />

                <div class="mb-3">
                    <label class="form-label fw-medium text-secondary">Danh mục nông sản</label>
                    <select class="form-select form-select-sm" name="danhMucId">
                        <option value="">-- Tất cả loại --</option>
                        @if (ViewBag.DanhMucList != null)
                        {
                            foreach (var dm in ViewBag.DanhMucList)
                            {
                                if (ViewBag.SelectedDanhMuc == dm.DanhMucId)
                                {
                                    <option value="@dm.DanhMucId" selected>@dm.TenDanhMuc</option>
                                }
                                else
                                {
                                    <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium text-secondary">Khoảng giá bán</label>
                    <select class="form-select form-select-sm" name="khoangGia">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.SelectedKhoangGia))">Tất cả mức giá</option>
                        <option value="under100" selected="@(ViewBag.SelectedKhoangGia == "under100")">Dưới 100.000đ</option>
                        <option value="100to300" selected="@(ViewBag.SelectedKhoangGia == "100to300")">100.000đ - 300.000đ</option>
                        <option value="over300" selected="@(ViewBag.SelectedKhoangGia == "over300")">Trên 300.000đ</option>
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-sm rounded-pill"><i class="bi bi-search"></i> Áp dụng lọc</button>
                    <a asp-controller="Search" asp-action="Index" asp-route-keyword="@ViewBag.Keyword" class="btn btn-outline-secondary btn-sm rounded-pill">Xóa bộ lọc</a>
                </div>
            </form>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0 text-success">
                    Từ khóa: <span class="text-dark">"@ViewBag.Keyword"</span>
                </h4>
                <span class="text-muted">Tìm thấy @Model.Count() sản phẩm phù hợp</span>
            </div>

            <div class="row g-3">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="col-md-4">
                            <div class="order-card shadow-sm p-3 h-100 d-flex flex-column justify-content-between">
                                <div>
                                    <div class="position-relative mb-3 text-center">
                                        <img src="@Url.Content("~/images/" + item.HinhAnh)" 
                                             class="img-fluid rounded-3" style="max-height: 160px; object-fit: cover;" alt="@item.TenNongSan" />
                                    </div>
                                    <h5 class="fw-semibold mb-2">@item.TenNongSan</h5>
                                    <p class="text-muted small mb-3 text-truncate-2">@item.MoTa</p>
                                </div>
                                <div>
                                    <div class="fw-bold text-success mb-3" style="font-size: 1.2rem;">@item.GiaBanNiemYet.ToString("#,##0")đ</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a class="btn btn-outline-success btn-sm" asp-controller="Product" asp-action="Detail" asp-route-id="@item.NongSanId">Xem chi tiết</a>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-success" 
                                                onclick="event.preventDefault(); event.stopPropagation(); quickAddToCart(@item.NongSanId);"
                                                title="Thêm vào giỏ hàng">
                                            Thêm vào giỏ
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <div class="text-muted mb-3"><i class="bi bi-search" style="font-size: 3rem;"></i></div>
                        <h5 class="text-secondary">Rất tiếc, không tìm thấy nông sản nào khớp với bộ lọc hiện tại.</h5>
                        <a asp-controller="Search" asp-action="Index" asp-route-keyword="@ViewBag.Keyword" class="btn btn-success mt-3 btn-sm">Xóa bộ lọc quay lại</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>