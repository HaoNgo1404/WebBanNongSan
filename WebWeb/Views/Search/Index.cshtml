@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />

<div class="container py-5 order-shell">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Tìm kiếm</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="order-card shadow-sm">
                <h5 class="fw-semibold mb-3">Bộ lọc</h5>
                <div class="mb-3">
                    <label class="form-label">Danh mục</label>
                    <select class="form-select form-select-sm">
                        <option>Tất cả</option>
                        <option>Rau củ</option>
                        <option>Trái cây</option>
                        <option>Thực phẩm sạch</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Khoảng giá</label>
                    <select class="form-select form-select-sm">
                        <option>Tất cả</option>
                        <option>Dưới 100k</option>
                        <option>100k - 300k</option>
                        <option>Trên 300k</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Xuất xứ</label>
                    <select class="form-select form-select-sm">
                        <option>Tất cả</option>
                        <option>Việt Nam</option>
                        <option>Úc</option>
                        <option>Mỹ</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Sắp xếp</label>
                    <select class="form-select form-select-sm">
                        <option>Mới nhất</option>
                        <option>Giá thấp đến cao</option>
                        <option>Giá cao đến thấp</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
                <div>
                    <h1 class="h3 fw-bold mb-1">Kết quả tìm kiếm</h1>
                    <p class="text-muted mb-0">Từ khóa: <span class="fw-semibold">Táo</span> • 3 kết quả</p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <div class="input-group" style="min-width: 280px;">
                        <input type="text" class="form-control" placeholder="Tìm nông sản..." />
                        <button class="btn btn-success" type="button">Tìm</button>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-xl-4">
                    <div class="order-card shadow-sm h-100">
                        <div class="position-relative mb-3">
                            <img src="https://images.unsplash.com/photo-1464965911861-746a04bca7d8?auto=format&fit=crop&w=900&q=80" class="img-fluid rounded-3" alt="Táo Mỹ" />
                            <span class="badge rounded-pill bg-success position-absolute top-0 start-0 m-3">Mới</span>
                        </div>
                        <h5 class="fw-semibold mb-2">Táo Mỹ</h5>
                        <p class="text-muted small mb-3">Táo đỏ ngọt, giàu vitamin C.</p>
                        <div class="fw-bold text-success mb-3">120.000đ</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-outline-success btn-sm" asp-controller="Product" asp-action="Detail" asp-route-id="1">Xem chi tiết</a>
                            <a class="btn btn-success btn-sm" asp-controller="Cart" asp-action="Index">Thêm vào giỏ</a>
                            <a class="btn btn-outline-danger btn-sm" asp-controller="Wishlist" asp-action="Add" asp-route-id="1">Yêu thích</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-4">
                    <div class="order-card shadow-sm h-100">
                        <div class="position-relative mb-3">
                            <img src="https://images.unsplash.com/photo-1567306226416-28f0efdc88ce?auto=format&fit=crop&w=900&q=80" class="img-fluid rounded-3" alt="Táo đỏ" />
                            <span class="badge rounded-pill bg-warning text-dark position-absolute top-0 start-0 m-3">Hot</span>
                        </div>
                        <h5 class="fw-semibold mb-2">Táo đỏ</h5>
                        <p class="text-muted small mb-3">Thơm ngọt, kích thước vừa.</p>
                        <div class="fw-bold text-success mb-3">85.000đ</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-outline-success btn-sm" asp-controller="Product" asp-action="Detail" asp-route-id="4">Xem chi tiết</a>
                            <a class="btn btn-success btn-sm" asp-controller="Cart" asp-action="Index">Thêm vào giỏ</a>
                            <a class="btn btn-outline-danger btn-sm" asp-controller="Wishlist" asp-action="Add" asp-route-id="4">Yêu thích</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-4">
                    <div class="order-card shadow-sm h-100">
                        <div class="position-relative mb-3">
                            <img src="https://images.unsplash.com/photo-1571771894821-ce9b6c11b08e?auto=format&fit=crop&w=900&q=80" class="img-fluid rounded-3" alt="Táo xanh" />
                            <span class="badge rounded-pill bg-info text-dark position-absolute top-0 start-0 m-3">Khuyến mãi</span>
                        </div>
                        <h5 class="fw-semibold mb-2">Táo xanh</h5>
                        <p class="text-muted small mb-3">Mềm mại, hương vị tươi mới.</p>
                        <div class="fw-bold text-success mb-3">98.000đ</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-outline-success btn-sm" asp-controller="Product" asp-action="Detail" asp-route-id="5">Xem chi tiết</a>
                            <a class="btn btn-success btn-sm" asp-controller="Cart" asp-action="Index">Thêm vào giỏ</a>
                            <a class="btn btn-outline-danger btn-sm" asp-controller="Wishlist" asp-action="Add" asp-route-id="5">Yêu thích</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-light border mt-4 mb-0">
                <strong>TODO:</strong> Hiển thị kết quả tìm kiếm thực tế khi Backend hoàn thiện.
            </div>

            <div class="mt-4">
                <partial name="_SearchSuggestion" />
            </div>
        </div>
    </div>
</div>
