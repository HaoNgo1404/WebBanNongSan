@model IEnumerable<WebWeb.Models.DonHangLe>
@{
    ViewData["Title"] = "Thông Báo Tiến Độ Đơn Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h3 class="fw-bold text-success mb-4">
                <i class="bi bi-bell-fill me-2"></i>THÔNG BÁO TIẾN ĐỘ ĐƠN HÀNG
            </h3>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-light text-center shadow-sm p-5 rounded-3">
                    <p class="text-muted m-0">Hào chưa có thông báo tiến độ nào vì chưa có đơn hàng nào được đặt!</p>
                </div>
            }
            else
            {
                <div class="nongsan-container" style="max-height: 380px; overflow-y: auto; padding-right: 8px;">
                    <div class="list-group shadow-sm rounded-3 overflow-hidden">
                        @foreach (var donHang in Model)
                        {
                            @* Trường hợp 1: Đơn hàng mới đặt - Chờ duyệt *@
                            @if (donHang.TrangThaiDonHang == WebWeb.Models.OrderStatuses.ChoDuyet)
                            {
                                <div class="list-group-item list-group-item-action p-4 border-start border-4 border-info mb-2 bg-white">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold text-info mb-0"><i class="bi bi-file-earmark-text me-1"></i> Đơn hàng đang chờ duyệt</h6>
                                        <small class="text-muted">@donHang.NgayDat.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <p class="mb-2 text-muted">Đơn hàng lẻ <strong>#@donHang.DonHangLeId</strong> đã được hệ thống tiếp nhận thành công. Ban quản trị đang tiến hành kiểm tra thông tin để duyệt đơn.</p>
                                    <a href="/Order/OrderHistoryDetail?id=@donHang.DonHangLeId" class="btn btn-sm btn-link p-0 text-info fw-semibold text-decoration-none">Xem chi tiết đơn &rarr;</a>
                                </div>
                            }

                            @* Trường hợp 2: Đơn hàng đã duyệt - Đang chuẩn bị hàng *@
                            else if (donHang.TrangThaiDonHang == WebWeb.Models.OrderStatuses.ChoXuLy)
                            {
                                <div class="list-group-item list-group-item-action p-4 border-start border-4 border-primary mb-2 bg-white">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold text-primary mb-0"><i class="bi bi-box-seam me-1"></i> Đơn hàng đã được duyệt</h6>
                                        <small class="text-muted">Cập nhật liên tục</small>
                                    </div>
                                    <p class="mb-2 text-muted">Đơn hàng <strong>#@donHang.DonHangLeId</strong> đã được xác nhận. Nhà vườn đang tiến hành thu hoạch nông sản tươi và đóng gói để chuẩn bị giao cho Shipper.</p>
                                    <a href="/Order/OrderHistoryDetail?id=@donHang.DonHangLeId" class="btn btn-sm btn-link p-0 text-primary fw-semibold text-decoration-none">Xem tiến độ đóng gói &rarr;</a>
                                </div>
                            }

                            @* Trường hợp 3: Đơn hàng đang giao *@
                            else if (donHang.TrangThaiDonHang == WebWeb.Models.OrderStatuses.DangGiao)
                            {
                                <div class="list-group-item list-group-item-action p-4 border-start border-4 border-warning mb-2 bg-light">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold text-warning mb-0"><i class="bi bi-truck me-1"></i> Đơn hàng đang được giao</h6>
                                        <span class="badge bg-warning text-dark small">Hot</span>
                                    </div>
                                    <p class="mb-2 text-dark">Đơn hàng <strong>#@donHang.DonHangLeId</strong> đang trên đường vận chuyển đến địa chỉ của Hào. Vui lòng chú ý điện thoại từ nhân viên giao hàng.</p>
                                    <a href="/Order/OrderHistoryDetail?id=@donHang.DonHangLeId" class="btn btn-sm btn-link p-0 text-warning fw-semibold text-decoration-none">Theo dõi lộ trình &rarr;</a>
                                </div>
                            }

                            @* Trường hợp 4: Đơn hàng hoàn thành *@
                            else if (donHang.TrangThaiDonHang == WebWeb.Models.OrderStatuses.HoanThanh)
                            {
                                <div class="list-group-item list-group-item-action p-4 border-start border-4 border-success mb-2 bg-white">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold text-success mb-0"><i class="bi bi-check2-circle me-1"></i> Giao hàng thành công 🎉</h6>
                                        <small class="text-muted">Đã hoàn thành</small>
                                    </div>
                                    <p class="mb-2 text-muted">Đơn hàng <strong>#@donHang.DonHangLeId</strong> đã được giao hoàn tất! Cảm ơn Hào đã ủng hộ nông sản sạch. Tài khoản của bạn đã được cập nhật điểm tích lũy thành viên tương ứng.</p>
                                    <a href="/Order/OrderHistoryDetail?id=@donHang.DonHangLeId" class="btn btn-sm btn-link p-0 text-success fw-semibold text-decoration-none">Đánh giá sản phẩm ngay &rarr;</a>
                                </div>
                            }

                            @* Trường hợp 5: Đơn hàng đã hủy *@
                            else if (donHang.TrangThaiDonHang == WebWeb.Models.OrderStatuses.DaHuy)
                            {
                                <div class="list-group-item list-group-item-action p-4 border-start border-4 border-secondary mb-2 bg-white opacity-75">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold text-secondary mb-0"><i class="bi bi-x-circle me-1"></i> Đơn hàng đã hủy</h6>
                                        <small class="text-muted">Đã hủy</small>
                                    </div>
                                    <p class="mb-2 text-muted">Đơn hàng <strong>#@donHang.DonHangLeId</strong> đã bị hủy bỏ trên hệ thống thành công.</p>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            <div class="text-center mt-4">
                <a href="/" class="btn btn-outline-success px-4 rounded-pill fw-semibold">
                    <i class="bi bi-house-door me-1"></i> Quay lại trang chủ
                </a>
            </div>
        </div>
    </div>
</div>