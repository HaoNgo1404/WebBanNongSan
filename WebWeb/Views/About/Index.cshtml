@{
    ViewData["Title"] = "Về Green Fresh";
}

<link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />

<div class="container py-5 order-shell">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Về Green Fresh</li>
        </ol>
    </nav>

    <div class="text-center mb-5">
        <h1 class="h2 fw-bold mb-2">Về Green Fresh</h1>
        <p class="text-muted mb-0">TODO: Thay bằng câu chuyện thương hiệu thật khi nội dung sẵn sàng.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="order-card shadow-sm h-100">
                <h4 class="fw-semibold mb-3">Câu chuyện thương hiệu</h4>
                <p class="text-muted">Green Fresh là nền tảng kết nối người tiêu dùng với các nông sản tươi sạch, an toàn và được kiểm soát từ nguồn gốc.</p>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="order-card shadow-sm h-100">
                <h4 class="fw-semibold mb-3">Sứ mệnh</h4>
                <p class="text-muted">Mang thực phẩm sạch đến gần hơn với mỗi gia đình, hỗ trợ nông dân và nâng cao chất lượng cuộc sống.</p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="order-card shadow-sm h-100">
                <h5 class="fw-semibold mb-2">Tầm nhìn</h5>
                <p class="text-muted small">TODO: Mô tả tầm nhìn dài hạn.</p>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="order-card shadow-sm h-100">
                <h5 class="fw-semibold mb-2">Giá trị cốt lõi</h5>
                <p class="text-muted small">Tinh khiết, minh bạch và bền vững.</p>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="order-card shadow-sm h-100">
                <h5 class="fw-semibold mb-2">Quy trình</h5>
                <p class="text-muted small">Từ nông trại đến tay khách hàng bằng quy trình kiểm soát chặt chẽ.</p>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="order-card shadow-sm h-100">
                <h5 class="fw-semibold mb-2">Vì sao chọn Green Fresh</h5>
                <p class="text-muted small">Giao hàng nhanh, chất lượng bảo đảm và dịch vụ tận tâm.</p>
            </div>
        </div>
    </div>
</div>
