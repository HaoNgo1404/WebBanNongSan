@model IEnumerable<WebWeb.Models.NongSan>
@{
    ViewData["Title"] = ViewBag.TenDanhMuc;
}

<div class="container py-4">
    <div class="row g-4">
        <aside class="col-lg-3 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 sticky-top" style="top: 90px; z-index: 10;">
                <h5 class="fw-bold text-success mb-3 pb-2 border-bottom">
                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>Danh mục nông sản
                </h5>
                <div class="list-group list-group-flush gap-1">
                    <a asp-controller="Product" asp-action="DanhMuc" asp-route-id="1" 
                       class="list-group-item list-group-item-action border-0 rounded-3 d-flex justify-content-between align-items-center fw-medium @(Context.Request.Query["id"] == "1" ? "active bg-success text-white" : "text-secondary")">
                        <span><i class="bi bi-flower1 me-2"></i>Rau củ</span>
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                    
                    <a asp-controller="Product" asp-action="DanhMuc" asp-route-id="2" 
                       class="list-group-item list-group-item-action border-0 rounded-3 d-flex justify-content-between align-items-center fw-medium @(Context.Request.Query["id"] == "2" ? "active bg-success text-white" : "text-secondary")">
                        <span><i class="bi bi-apple me-2"></i>Trái cây</span>
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                    
                    <a asp-controller="Product" asp-action="DanhMuc" asp-route-id="3" 
                       class="list-group-item list-group-item-action border-0 rounded-3 d-flex justify-content-between align-items-center fw-medium @(Context.Request.Query["id"] == "3" ? "active bg-success text-white" : "text-secondary")">
                        <span><i class="bi bi-shield-check me-2"></i>Thực phẩm sạch</span>
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                </div>
            </div>
        </aside>

        <main class="col-lg-9 col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold text-dark mb-0">@ViewBag.TenDanhMuc</h3>
                <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill fs-6 fw-normal">
                    Tìm thấy <strong>@Model.Count()</strong> mặt hàng
                </span>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center py-5 rounded-4 border-0 shadow-sm">
                    <i class="bi bi-box-seam fs-1 d-block mb-3 text-muted"></i>
                    Hiện chưa có mặt hàng nào thuộc nhóm danh mục này.
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card transition-all" style="transition: transform 0.2s;">
                                <div class="position-relative overflow-hidden">
                                    <img src="@Url.Content("~/images/" + item.HinhAnh)" class="card-img-top object-fit-cover w-100" alt="@item.TenNongSan" style="height: 200px;">
                                </div>
                                <div class="card-body p-3 d-flex flex-column">
                                    <h6 class="card-title fw-bold mb-1 text-dark text-truncate">@item.TenNongSan</h6>
                                    <p class="small text-muted mb-3 text-truncate-2 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: 13px;">@item.MoTa</p>
                                    
                                    <div class="d-flex justify-content-between align-items-center mt-auto">
                                        <div>
                                            <span class="text-danger fw-bold fs-5">@item.GiaBanNiemYet.ToString("N0")₫</span>
                                            <small class="text-muted">/@item.DonViTinh</small>
                                        </div>
                                        <a asp-action="Detail" asp-route-id="@item.NongSanId" class="btn btn-success btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                            <i class="bi bi-eye fs-5"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>