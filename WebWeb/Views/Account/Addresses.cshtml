@using System.Text.Encodings.Web
@model IEnumerable<WebWeb.Models.SoDiaChi>
@{
    ViewData["Title"] = "Quản lý địa chỉ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Nhúng thư viện CSS & JS Bản đồ mở (Thêm vào đầu file Addresses.cshtml) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    /* Đảm bảo các mảnh bản đồ hiển thị mượt mà, không bị vỡ hoặc ẩn mất */
    .leaflet-container {
        font-family: inherit;
    }
    #map-selection img {
        max-width: none !important;
        max-height: none !important;
    }
</style>

<div class="account-dashboard">
    <div class="row g-4">
        <div class="col-lg-3">
            <partial name="_AccountSidebar" />
        </div>
        <div class="col-lg-9">
            <div class="dashboard-content card p-4 shadow-sm border-0 rounded-4 bg-white">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <p class="section-label mb-0 text-success fw-bold text-uppercase small">Tài khoản</p>
                        <h2 class="mb-0 fw-bold text-dark">Quản lý sổ địa chỉ</h2>
                    </div>
                    <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" onclick="openAddressModal(0)">
                        <i class="bi bi-plus-lg"></i> Thêm địa chỉ mới
                    </button>
                </div>

                <div class="address-list d-flex flex-column gap-3">
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5 bg-light rounded-4 border border-dashed">
                            <i class="bi bi-geo text-muted fs-1"></i>
                            <p class="text-muted mt-2 mb-0">Bạn chưa lưu địa chỉ giao hàng nào.</p>
                        </div>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <div class="address-card p-3 border rounded-4 bg-light @(item.IsDefault ? "border-success bg-success-subtle bg-opacity-10" : "")">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h5 class="mb-1 fw-bold text-dark">
                                            @item.TenNguoiNhan 
                                            @if (!string.IsNullOrEmpty(item.LoaiDiaChi))
                                            {
                                                <span class="badge bg-secondary small ms-2 fw-normal">@item.LoaiDiaChi</span>
                                            }
                                        </h5>
                                        <p class="text-muted mb-0 small"><i class="bi bi-telephone"></i> @item.SoDienThoaiNhan</p>
                                    </div>
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge bg-success rounded-pill px-2.5 py-1 shadow-sm"><i class="bi bi-check-circle-fill"></i> Mặc định</span>
                                    }
                                </div>
                                <p class="mb-3 text-dark"><i class="bi bi-geo-alt"></i> @item.DiaChiGiao</p>
                                <div class="address-actions d-flex gap-2">
                                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" 
                                            onclick="openAddressModal(@item.DiaChiId, '@JavaScriptEncoder.Default.Encode(item.TenNguoiNhan)', '@item.SoDienThoaiNhan', '@JavaScriptEncoder.Default.Encode(item.DiaChiGiao)', '@item.LoaiDiaChi', @item.IsDefault.ToString().ToLower())">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </button>
                                    
                                    @if (!item.IsDefault)
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3" onclick="deleteAddress(@item.DiaChiId)">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                        <button class="btn btn-outline-success btn-sm rounded-pill px-3" onclick="setDefaultAddress(@item.DiaChiId)">
                                            Đặt mặc định
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addressModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="modalTitle">Địa chỉ nhận hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addressForm">
                    <input type="hidden" id="DiaChiId" name="DiaChiId" value="0" />
                    
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Tên người nhận <span class="text-danger">*</span></label>
                        <input type="text" class="form-control rounded-3" id="TenNguoiNhan" name="TenNguoiNhan" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Số điện thoại nhận <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control rounded-3" id="SoDienThoaiNhan" name="SoDienThoaiNhan" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Địa chỉ giao hàng cụ thể <span class="text-danger">*</span></label>
                        <textarea class="form-control rounded-3" id="DiaChiGiao" name="DiaChiGiao" rows="2" required placeholder="Nhập địa chỉ hoặc chọn trực tiếp trên bản đồ phía dưới..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold d-flex justify-content-between">
                            <span><i class="bi bi-map"></i> Bản đồ định vị nhanh</span>
                            <span class="text-success small fw-normal"><i class="bi bi-info-circle"></i> Di chuyển marker để chọn vị trí chính xác</span>
                        </label>
                        <!-- Tạo khung chứa bản đồ có bo viền đồng bộ giao diện -->
                        <div id="map-selection" class="border rounded-3 shadow-sm bg-light" style="width: 100%; height: 260px; position: relative; z-index: 1;"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Loại địa chỉ</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="LoaiDiaChi" id="typeNhaRieng" value="Nhà riêng" checked>
                                <label class="form-check-label" for="typeNhaRieng">Nhà riêng</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="LoaiDiaChi" id="typeVanPhong" value="Văn phòng">
                                <label class="form-check-label" for="typeVanPhong">Văn phòng / Cơ quan</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-2" id="divDefaultCheckbox">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="IsDefault" name="IsDefault" value="true">
                            <label class="form-check-label small text-secondary fw-bold" for="IsDefault">Đặt làm địa chỉ nhận hàng mặc định</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-3" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-success rounded-pill px-4 fw-bold" onclick="submitAddressForm()">Lưu lại</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Khởi tạo bản đồ Leaflet
        var mapInstance = null;
        var mapMarker = null;

        // Hàm khởi tạo và cấu hình Bản đồ
        function initMapSelection() {
            // Tọa độ mặc định (Ví dụ: Trung tâm TP.HCM hoặc Hà Nội)
            const defaultLat = 10.762622;
            const defaultLng = 106.660172;

            // Nếu bản đồ chưa được dựng lên lần nào
            if (mapInstance === null) {
                // Tọa độ trung tâm mặc định (Ví dụ đặt ở Việt Nam: 10.762622, 106.660172)
                mapInstance = L.map('map-selection').setView([10.762622, 106.660172], 13);

                // Nạp giao diện bản đồ từ OpenStreetMap vệ tinh mở
                L.tileLayer('https://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}', {
                    maxZoom: 20,
                    subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
                    attribution: '&copy; Google Maps'
                }).addTo(mapInstance);

                // Tạo dấu Marker cho phép người dùng bấm giữ và kéo đi bất cứ đâu (draggable: true)
                mapMarker = L.marker([10.762622, 106.660172], { draggable: true }).addTo(mapInstance);

                // Sự kiện 1: Khi kết thúc hành động kéo Marker, tự động dịch ngược tọa độ sang chữ địa chỉ
                mapMarker.on('dragend', function (e) {
                    var position = mapMarker.getLatLng();
                    getAddressFromCoords(position.lat, position.lng);
                });

                // Sự kiện 2: Khi người dùng click chuột vào bất kỳ điểm nào trên bản đồ, di chuyển marker tới đó và dịch chữ
                mapInstance.on('click', function (e) {
                    mapMarker.setLatLng(e.latlng);
                    getAddressFromCoords(e.latlng.lat, e.latlng.lng);
                });
            }

            // Fix lỗi hiển thị của Leaflet khi nằm trong Modal Bootstrap (Kích hoạt vẽ lại kích thước)
            setTimeout(function() {
                mapInstance.invalidateSize();
            }, 400);
        }

        function getAddressFromCoords(lat, lng) {
            var apiUrl = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&addressdetails=1&accept-language=vi`;

            fetch(apiUrl)
            .then(res => res.json())
            .then(data => {
                if (data && data.display_name) {
                    // 1. Tách chuỗi địa chỉ thành mảng dựa trên dấu phẩy
                    let rawParts = data.display_name.split(',').map(item => item.trim());

                    // 2. Loại bỏ các phần thừa (Mã bưu chính, Quốc gia Việt Nam)
                    let filteredParts = rawParts.filter(part => {
                        let isZipCode = /^\d{5,6}$/.test(part);
                        let isCountry = /^Việt Nam$/i.test(part);
                        return !isZipCode && !isCountry;
                    });

                    // 3. Khởi tạo cấu trúc 4 cấp chuẩn
                    let province = ""; // Tỉnh / Thành phố
                    let district = ""; // Quận / Huyện / Thị xã
                    let ward = "";     // Phường / Xã / Thị trấn
                    let street = "";   // Số nhà + Tên đường

                    // Lấy từ dưới lên (Right-to-Left)
                    if (filteredParts.length > 0) {
                        province = filteredParts.pop(); // Phần cuối cùng luôn là Tỉnh/Thành phố
                    }

                    if (filteredParts.length > 0) {
                        let nextPart = filteredParts[filteredParts.length - 1];
                        // Kiểm tra nếu phần tiếp theo là Quận/Huyện hoặc Thành phố thuộc tỉnh (như Thủ Đức)
                        if (/^(Quận|Huyện|Thị xã|Thành phố)\b/i.test(nextPart) || filteredParts.length <= 2) {
                            district = filteredParts.pop();
                        }
                    }

                    if (filteredParts.length > 0) {
                        let nextPart = filteredParts[filteredParts.length - 1];
                        // Kiểm tra nếu là Phường/Xã/Thị trấn
                        if (/^(Phường|Xã|Thị trấn)\b/i.test(nextPart) || filteredParts.length <= 2) {
                            ward = filteredParts.pop();
                        }
                    }

                    // Toàn bộ các phần còn lại ở đầu sẽ là Số nhà / Tên đường / Tên tòa nhà
                    if (filteredParts.length > 0) {
                        street = filteredParts.join(', ');
                    }

                    // 4. Ghép lại thành chuỗi địa chỉ 4 cấp hoàn chỉnh
                    let finalParts = [];
                    if (street) finalParts.push(street);
                    if (ward) finalParts.push(ward);
                    if (district) finalParts.push(district);
                    if (province) finalParts.push(province);

                    let resultAddress = finalParts.join(', ');

                    // Nếu lọc xong bị lỗi thì giữ lại chuỗi gốc sạch
                    if (!resultAddress) {
                        resultAddress = data.display_name.replace(/,?\s*\b\d{5,6}\b/g, '').replace(/,\s*Việt Nam$/i, '').trim();
                    }

                    // Đổ kết quả vào ô Textarea
                    document.getElementById('DiaChiGiao').value = resultAddress;
                }
            })
            .catch(err => console.error("Lỗi lấy địa chỉ từ Nominatim:", err));
        }

        // CẬP NHẬT: Sửa lại hàm openAddressModal cũ của bạn để kích hoạt bản đồ mượt mà
        function openAddressModal(id, name = '', phone = '', address = '', type = 'Nhà riêng', isDefault = false) {
            document.getElementById('addressForm').reset();
            document.getElementById('DiaChiId').value = id;
            
            if (id === 0) {
                document.getElementById('modalTitle').innerText = "Thêm địa chỉ giao nhận mới";
                document.getElementById('divDefaultCheckbox').style.display = "block";
            } else {
                document.getElementById('modalTitle').innerText = "Cập nhật địa chỉ nhận hàng";
                document.getElementById('TenNguoiNhan').value = name;
                document.getElementById('SoDienThoaiNhan').value = phone;
                document.getElementById('DiaChiGiao').value = address;
                
                if (type === 'Văn phòng') {
                    document.getElementById('typeVanPhong').checked = true;
                } else {
                    document.getElementById('typeNhaRieng').checked = true;
                }

                if (isDefault) {
                    document.getElementById('divDefaultCheckbox').style.display = "none";
                    document.getElementById('IsDefault').checked = true;
                } else {
                    document.getElementById('divDefaultCheckbox').style.display = "block";
                    document.getElementById('IsDefault').checked = false;
                }
            }
            
            var myModal = new bootstrap.Modal(document.getElementById('addressModal'));
            myModal.show();

            // Kích hoạt nạp bản đồ lên ngay sau khi mở modal thành công
            initMapSelection();
        }
        
        // Gọi hiển thị Modal (id = 0 là Thêm mới, id > 0 là sửa)
        // 1. SỬA LẠI HÀM OPEN MODAL: Chỉ làm nhiệm vụ đổ dữ liệu và bật Modal lên
        function openAddressModal(id, name = '', phone = '', address = '', type = 'Nhà riêng', isDefault = false) {
            document.getElementById('addressForm').reset();
            document.getElementById('DiaChiId').value = id;
            
            if (id === 0) {
                document.getElementById('modalTitle').innerText = "Thêm địa chỉ giao nhận mới";
                document.getElementById('divDefaultCheckbox').style.display = "block";
            } else {
                document.getElementById('modalTitle').innerText = "Cập nhật địa chỉ nhận hàng";
                document.getElementById('TenNguoiNhan').value = name;
                document.getElementById('SoDienThoaiNhan').value = phone;
                document.getElementById('DiaChiGiao').value = address;
                
                if (type === 'Văn phòng') {
                    document.getElementById('typeVanPhong').checked = true;
                } else {
                    document.getElementById('typeNhaRieng').checked = true;
                }

                if (isDefault) {
                    document.getElementById('divDefaultCheckbox').style.display = "none";
                    document.getElementById('IsDefault').checked = true;
                } else {
                    document.getElementById('divDefaultCheckbox').style.display = "block";
                    document.getElementById('IsDefault').checked = false;
                }
            }
            
            // Bật modal lên bình thường
            var myModal = new bootstrap.Modal(document.getElementById('addressModal'));
            myModal.show();
        }

        // 2. BỔ SUNG: Bắt sự kiện Modal ĐÃ HIỂN THỊ XONG hoàn toàn thì mới dựng bản đồ
        document.addEventListener("DOMContentLoaded", function () {
            const addressModalEl = document.getElementById('addressModal');
            if (addressModalEl) {
                addressModalEl.addEventListener('shown.bs.modal', function () {
                    // Khởi tạo hoặc cập nhật lại bản đồ khi vùng chứa đã có kích thước thực tế
                    initMapSelection();
                });
            }
        });

        // Thực hiện gửi dữ liệu Lưu (Add/Edit) thông qua AJAX Fetch ngầm
        function submitAddressForm() {
            const form = document.getElementById('addressForm');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const formData = new FormData(form);
            // Đảm bảo xử lý đúng giá trị checkbox boolean switch của ASP.NET
            if (!formData.has('IsDefault')) {
                formData.append('IsDefault', 'false');
            }

            fetch('@Url.Action("SaveAddress", "Account")', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(err => console.error("Lỗi:", err));
        }

        // Đặt địa chỉ mặc định nhanh
        function setDefaultAddress(id) {
            fetch('@Url.Action("SetDefaultAddress", "Account")?id=' + id, { method: 'POST' })
            .then(res => res.json())
            .then(data => { if (data.success) window.location.reload(); })
            .catch(err => console.error(err));
        }

        // Gửi lệnh xóa địa chỉ lẻ
        function deleteAddress(id) {
            if (confirm("Hào có chắc chắn muốn xóa địa chỉ này khỏi sổ tay không?")) {
                fetch('@Url.Action("DeleteAddress", "Account")?id=' + id, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        window.location.reload();
                    } else {
                        alert(data.message);
                    }
                })
                .catch(err => console.error(err));
            }
        }
    </script>
}