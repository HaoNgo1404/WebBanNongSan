@model WebWeb.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="account-shell">
    <div class="account-card auth-card">
        <div class="auth-brand">
            <div class="brand-icon"><i class="bi bi-flower3"></i></div>
            <div>
                <h3>Fresh Farm</h3>
                <p>Khôi phục mật khẩu</p>
            </div>
        </div>

        <p class="text-muted">Nhập email của bạn để nhận hướng dẫn đặt lại mật khẩu.</p>

        <form asp-action="ForgotPassword" class="auth-form">
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Nhập email đăng ký" />
            </div>
            <button type="submit" class="btn btn-success w-100 mb-3">Gửi yêu cầu</button>
            <p class="text-center text-muted mb-0"><a asp-action="Login" class="text-success fw-semibold">Quay lại đăng nhập</a></p>
        </form>
    </div>
</div>
