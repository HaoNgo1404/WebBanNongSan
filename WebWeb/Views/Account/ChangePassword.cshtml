@model WebWeb.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}
<div class="account-dashboard">
    <div class="row g-4">
        <div class="col-lg-3">
            <partial name="_AccountSidebar" />
        </div>

        <div class="col-lg-9">
            <div class="dashboard-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold text-success text-center mb-4"><i class="bi bi-shield-lock me-2"></i>Thay đổi mật khẩu</h3>
                </div>    
                    
                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success rounded-3 text-center">@ViewBag.SuccessMessage</div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-medium">Mật khẩu hiện tại</label>
                            <input asp-for="OldPassword" type="password" class="form-control rounded-3" placeholder="Nhập mật khẩu hiện tại" />
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium">Mật khẩu mới</label>
                            <input asp-for="NewPassword" type="password" class="form-control rounded-3" placeholder="Tối thiểu 6 ký tự" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium">Xác nhận mật khẩu mới</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="Nhập lại mật khẩu mới" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2.5 rounded-3 fw-bold mb-2">Cập nhật mật khẩu</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light w-100 py-2.5 rounded-3 text-secondary">Quay lại trang chủ</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>    