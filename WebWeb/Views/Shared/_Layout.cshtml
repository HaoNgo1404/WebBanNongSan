<!DOCTYPE html>
<html lang="en">
@using System.Security.Claims
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenFresh</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="bi bi-flower3"></i></span>
                    <span>Green Fresh</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <form class="d-flex flex-grow-1 mx-lg-4 position-relative search-form" asp-controller="Search" asp-action="Index" method="get" autocomplete="off">
                            <i class="bi bi-search"></i>
                            <input type="text" name="keyword" id="txtSearchHeader" class="form-control" placeholder="Tìm nông sản, rau củ, trái cây..." value="@ViewBag.Keyword"/>
                        <div id="searchSuggestionWrapper" class="position-absolute w-100 mt-1 d-none" style="z-index: 9999; top: 100%; left: 0;"></div>
                    </form>
                    <ul class="navbar-nav align-items-center gap-2">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Danh mục</a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Product"
                                    asp-action="DanhMuc"
                                    asp-route-id="1">
                                        Rau củ
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Product"
                                    asp-action="DanhMuc"
                                    asp-route-id="2">
                                        Trái cây
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Product"
                                    asp-action="DanhMuc"
                                    asp-route-id="3">
                                        Thực phẩm sạch
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="About" asp-action="Index">Giới thiệu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link action-pill" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart"></i> Yêu thích</a>
                        </li>
                        <li class="nav-item">
                            <div class="nav-item dropdown position-relative">
                                <a class="nav-link action-pill" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-cart3 fs-4"></i>
                                    @inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
                                    @using System.Text.Json
                                    @{
                                        var sessionCart = HttpContextAccessor.HttpContext?.Session.GetString("UserCart");
                                        var currentCart = sessionCart == null ? new List<WebWeb.Models.GioHang>() : JsonSerializer.Deserialize<List<WebWeb.Models.GioHang>>(sessionCart);
                                        var totalQty = currentCart?.Sum(c => c.SoLuong);
                                    }
                                    @if (totalQty > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                                            @totalQty
                                        </span>
                                    }
                                </a>
                                
                                <div class="dropdown-menu dropdown-menu-end p-0 border-0">
                                    @await Html.PartialAsync("~/Views/Cart/MiniCart.cshtml", currentCart)
                                </div>
                            </div>
                        </li>
                        <li class="nav-item">
                            <div class="dropdown me-3">
                                <a class="nav-item position-relative dropdown" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell fs-5 text-dark"></i>
                                    <span class="position-absolute top-2 start-75 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                                </a>
                                
                                <div class="dropdown-menu dropdown-menu-end shadow-sm p-0 border-0 rounded-3" aria-labelledby="notificationDropdown" style="width: 360px; max-height: 450px; overflow-y: auto;">
                                    <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center rounded-top-3">
                                        <h6 class="fw-bold text-success m-0"><i class="bi bi-bell-fill me-1"></i> Thông báo mới nhất</h6>
                                        <a href="/Notification/TrackingOrder" class="small text-decoration-none text-muted">Xem tất cả</a>
                                    </div>
                                    
                                    <div class="list-group list-group-flush" id="notiDropdownContainer">
                                        <div class="p-4 text-center text-muted small" id="notiEmptyText">
                                            <i class="bi bi-chat-left-dots fs-3 d-block mb-2 opacity-50"></i> Đang tải thông báo...
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="nav-item">
                            <div class="d-flex align-items-center gap-3">
                                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer"))
                                {
                                    <div class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 fw-medium text-dark" 
                                        href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <div class="avatar-small bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" 
                                                style="width: 32px; height: 32px; font-size: 14px;">
                                                @{
                                                    var hoTen = User.FindFirstValue(ClaimTypes.Name) ?? "U";
                                                    @hoTen.Substring(0, 1).ToUpper()
                                                }
                                            </div>
                                            <span>Chào, @hoTen</span>
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-3">
                                            <li>
                                                <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile">
                                                    <i class="bi bi-person me-2 text-muted"></i>Hồ sơ cá nhân
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item py-2" asp-controller="Account" asp-action="Addresses">
                                                    <i class="bi bi-geo-alt me-2 text-muted"></i>Sổ địa chỉ
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item py-2" asp-controller="Account" asp-action="ChangePassword">
                                                    <i class="bi bi-shield-lock me-2 text-muted"></i>Đổi mật khẩu
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout">
                                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-link text-decoration-none text-dark fw-medium p-0">Đăng nhập</a>
                                    <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-sm px-3 py-2 rounded-3 fw-bold">Đăng ký</a>
                                }
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="site-main">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Green Fresh</h5>
                    <p class="text-muted mb-0">Mang đến nông sản sạch, tươi ngon và an toàn từ những trang trại chất lượng.</p>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-semibold mb-3">Danh mục</h6>
                    <ul class="footer-links">
                        <li>
                            <a class="dropdown-item"
                            asp-controller="Product"
                            asp-action="DanhMuc"
                            asp-route-id="1">
                                Rau củ
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                            asp-controller="Product"
                            asp-action="DanhMuc"
                            asp-route-id="2">
                                Trái cây
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                            asp-controller="Product"
                            asp-action="DanhMuc"
                            asp-route-id="3">
                                Thực phẩm sạch
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-semibold mb-3">Chính sách</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="VanChuyen">Chính sách vận chuyển</a></li>
                        <li><a asp-controller="Home" asp-action="DoiTra">Đổi trả hàng</a></li>
                        <li><a asp-controller="Home" asp-action="BaoMat">Bảo mật thông tin</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-semibold mb-3">Liên hệ</h6>
                    <ul class="footer-links">
                        <li><a href="tel:0123456789"><i class="bi bi-telephone"></i> 0123 456 789</a></li>
                        <li><a href="mailto:support@greenfresh.vn"><i class="bi bi-envelope"></i> support@greenfresh.vn</a></li>
                        <li><a href="https://instagram.com/greenfresh" target="_blank"><i class="bi bi-instagram"></i> @@greenfresh</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>© 2026 Green Fresh. All rights reserved.</span>
                <div class="social-links">
                    <a href="https://facebook.com/greenfresh" target="_blank"><i class="bi bi-facebook"></i></a>
                    <a href="https://instagram.com/greenfresh" target="_blank"><i class="bi bi-instagram"></i></a>
                    <a href="https://youtube.com/greenfresh" target="_blank"><i class="bi bi-youtube"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <div class="modal fade" id="orderTrackingModal" tabindex="-1" aria-labelledby="orderTrackingModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-3">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold" id="orderTrackingModalLabel"><i class="bi bi-geo-fill me-1"></i> TIẾN ĐỘ ĐƠN HÀNG</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-shadow="none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center" id="trackingModalBody">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>
    <script src="~/js/order.js" asp-append-version="true"></script>
    <script src="~/js/notification.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (TempData["NewUserWelcome"] != null)
    {
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    title: '🎉 QUÀ RA MẮT THÀNH VIÊN MỚI! 🎉',
                    html: `@Html.Raw(TempData["NewUserWelcome"])`,
                    icon: 'success',
                    confirmButtonText: 'Tuyệt vời, mua sắm ngay!',
                    confirmButtonColor: '#198754', // Màu xanh thương hiệu
                    allowOutsideClick: true
                });
            });
        </script>
    }
    else if (TempData["SuccessMessage"] != null)
    {
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                Swal.fire({
                    title: 'CHÀO MỪNG TRỞ LẠI!',
                    html: `@Html.Raw(TempData["SuccessMessage"])`,
                    icon: 'success',
                    confirmButtonText: 'Bắt đầu mua sắm ngay!',
                    confirmButtonColor: '#198754', // Màu xanh thương hiệu
                    allowOutsideClick: true
                });
            });
        </script>
    }

<style>
    /* Nút bong bóng chat nổi tròn tròn ở góc dưới bên phải */
    #chatbot-bubble {
        position: fixed;
        bottom: 25px;
        right: 25px;
        width: 60px;
        height: 60px;
        background-color: #198754; /* Màu xanh lá cây thương hiệu */
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.25);
        z-index: 9999;
        transition: all 0.3s ease;
    }
    #chatbot-bubble:hover {
        transform: scale(1.1);
        background-color: #157347;
    }
    /* Hộp thoại chat ẩn/hiện */
    #chatbot-box {
        position: fixed;
        bottom: 95px;
        right: 25px;
        width: 350px;
        height: 480px;
        background-color: white;
        border-radius: 12px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.15);
        display: none; /* Mặc định ẩn */
        flex-direction: column;
        z-index: 9999;
        overflow: hidden;
        border: 1px solid #e1e1e1;
    }
    /* Header hộp chat */
    .chat-header {
        background-color: #198754;
        color: white;
        padding: 12px 15px;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    /* Khung chứa các dòng tin nhắn */
    .chat-messages {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background-color: #f8f9fa;
    }
    /* Bong bóng tin nhắn */
    .message {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 15px;
        font-size: 14px;
        line-height: 1.4;
    }
    .message.user {
        background-color: #d1e7dd;
        color: #0f5132;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }
    .message.bot {
        background-color: white;
        color: #212529;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #dee2e6;
    }
    /* Form gõ tin nhắn */
    .chat-input-area {
        padding: 10px;
        border-top: 1px solid #dee2e6;
        display: flex;
        gap: 8px;
        background: white;
    }
    .chat-input-area input {
        flex: 1;
        border: 1px solid #ced4da;
        border-radius: 20px;
        padding: 6px 15px;
        font-size: 14px;
        outline: none;
    }
</style>

<div id="chatbot-bubble">
    <i class="bi bi-chat-dots-fill"></i>
</div>

<div id="chatbot-box" class="flex-column">
    <div class="chat-header">
        <span class="d-flex align-items-center"><i class="bi bi-robot me-2"></i> Trợ lý ảo Green Fresh</span>
        <button type="button" class="btn-close btn-close-white" style="font-size: 12px;" id="close-chat"></button>
    </div>
    <div class="chat-messages" id="chat-messages-container">
        @* <div class="message bot">
            Xin chào! Em là trợ lý ảo thông minh của Green Fresh. Em có thể giúp gì cho Anh/Chị hôm nay ạ? 🌱🌸
        </div> *@
    </div>
    <div class="chat-input-area">
        <input type="text" id="user-chat-input" placeholder="Nhập câu hỏi của bạn..." autocomplete="off">
        <button class="btn btn-success btn-sm rounded-circle px-2" id="send-chat-btn">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const bubble = document.getElementById('chatbot-bubble');
        const box = document.getElementById('chatbot-box');
        const closeBtn = document.getElementById('close-chat');
        const sendBtn = document.getElementById('send-chat-btn');
        const inputField = document.getElementById('user-chat-input');
        const messagesContainer = document.getElementById('chat-messages-container');

        // Biến kiểm tra xem câu chào mừng đã chạy chưa
        let isWelcomeTyped = false; 
        const welcomeMessage = "Xin chào! Em là trợ lý ảo thông minh của Green Fresh. Em có thể giúp gì cho Anh/Chị hôm nay ạ? 🌱🌸";

        // 1. Click bong bóng để mở/đóng khung chat
        bubble.addEventListener('click', () => {
            const isOpening = (box.style.display !== 'flex');
            box.style.display = isOpening ? 'flex' : 'none';
            inputField.focus();

            // Nếu đang mở hộp chat VÀ chưa từng chạy câu chào mừng
            if (isOpening && !isWelcomeTyped) {
                isWelcomeTyped = true; // Đánh dấu đã chạy để không lặp lại lần sau
                
                // Chờ hộp chat hiển thị hoàn toàn rồi bắt đầu gõ chữ (delay 100ms cho mượt)
                setTimeout(() => {
                    appendMessageWithTypingEffect(welcomeMessage, 'bot');
                }, 100);
            }
        });

        // 2. Click nút Close để đóng khung chat
        closeBtn.addEventListener('click', () => {
            box.style.display = 'none';
        });

        // 3. Hàm gửi tin nhắn
        function sendMessage() {
            const messageText = inputField.value.trim();
            if (!messageText) return;

            // Hiển thị tin nhắn của Người dùng lên khung
            appendMessage(messageText, 'user');
            inputField.value = '';

            // Hiển thị biểu tượng AI đang suy nghĩ (Đang gõ...)
            const typingIndicatorId = 'typing-' + Date.now();
            appendTypingIndicator(typingIndicatorId);

            // Gửi Ajax lên BotController
            fetch('/api/Bot/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ message: messageText })
            })
            .then(response => response.json())
            .then(data => {
                // Xóa biểu tượng đang suy nghĩ
                removeTypingIndicator(typingIndicatorId);
                // Hiển thị câu trả lời của AI với hiệu ứng gõ chữ
                appendMessageWithTypingEffect(data.response, 'bot');
            })
            .catch(error => {
                console.error("Lỗi Chatbot:", error);
                removeTypingIndicator(typingIndicatorId);
                appendMessageWithTypingEffect("Dạ, kết nối mạng của em đang bị gián đoạn, anh/chị chờ em một xíu nhé!", 'bot');
            });
        }

        // Đăng ký sự kiện click gửi tin nhắn
        sendBtn.addEventListener('click', sendMessage);

        // Đăng ký sự kiện nhấn phím Enter để gửi tin nhắn
        inputField.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        // Hàm chèn tin nhắn tĩnh thông thường (dành cho User)
        function appendMessage(text, sender) {
            const msgDiv = document.createElement('div');
            msgDiv.classList.add('message', sender);
            msgDiv.innerHTML = text.replace(/\n/g, '<br>'); // Hỗ trợ xuống dòng
            messagesContainer.appendChild(msgDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight; // Tự động cuộn xuống dưới cùng
        }

        // Hiển thị tin nhắn của Bot từng ký tự một (Typing Effect)
        function appendMessageWithTypingEffect(text, sender) {
            const msgDiv = document.createElement('div');
            msgDiv.classList.add('message', sender);
            messagesContainer.appendChild(msgDiv);

            let index = 0;
            const typingSpeed = 15; // Tốc độ gõ chữ (15ms/ký tự)

            // Định dạng trước xuống dòng
            const htmlFormattedText = text.replace(/\n/g, '<br>');
            
            function typeCharacter() {
                if (index < htmlFormattedText.length) {
                    if (htmlFormattedText.substring(index, index + 4) === '<br>') {
                        msgDiv.innerHTML += '<br>';
                        index += 4;
                    } else {
                        msgDiv.innerHTML += htmlFormattedText.charAt(index);
                        index++;
                    }
                    
                    messagesContainer.scrollTop = messagesContainer.scrollHeight; // Cuộn mượt theo chữ chạy
                    setTimeout(typeCharacter, typingSpeed);
                }
            }

            typeCharacter();
        }

        // Hàm tạo hiệu ứng "AI đang suy nghĩ"
        function appendTypingIndicator(id) {
            const indicatorDiv = document.createElement('div');
            indicatorDiv.id = id;
            indicatorDiv.classList.add('message', 'bot');
            indicatorDiv.innerHTML = `<span class="spinner-grow spinner-grow-sm text-success" role="status"></span> Đang suy nghĩ...`;
            messagesContainer.appendChild(indicatorDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        // Hàm xóa hiệu ứng "AI đang suy nghĩ"
        function removeTypingIndicator(id) {
            const elem = document.getElementById(id);
            if (elem) elem.remove();
        }
    });
</script>
</body>
</html>