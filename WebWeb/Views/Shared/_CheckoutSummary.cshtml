@model WebWeb.Models.ViewModels.CheckoutViewModel

<div class="card p-3 bg-light shadow-sm rounded-3 border">
    <h5 class="fw-bold mb-3"><i class="bi bi-basket3-fill text-success"></i> Tóm tắt nông sản đặt mua</h5>
    <hr class="mt-0" />
    
    @if (Model.Items != null && Model.Items.Any())
    {
        decimal tongTienTamTinh = 0;
        
        // Vòng lặp for để vừa hiển thị vừa tạo các thẻ input ẩn nhằm phục vụ việc SUBMIT form lên Controller
        @for (int i = 0; i < Model.Items.Count; i++)
        {
            // Các thẻ ẩn này vô cùng quan trọng để Model Binder của ASP.NET Core bắt được mảng Items khi nhấn nút Đặt Hàng
            <input type="hidden" name="Items[@i].NongSanId" value="@Model.Items[i].NongSanId" />
            <input type="hidden" name="Items[@i].SoLuongDat" value="@Model.Items[i].SoLuongDat" />
            <input type="hidden" name="Items[@i].DonGiaThoiDiem" value="@Model.Items[i].DonGiaThoiDiem" />
            
            decimal thanhTienRow = Model.Items[i].SoLuongDat * Model.Items[i].DonGiaThoiDiem;
            tongTienTamTinh += thanhTienRow;

            <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                <div>
                    <h6 class="mb-0 fw-bold text-dark">Mã nông sản: #@Model.Items[i].NongSanId</h6>
                    <small class="text-muted">Số lượng: <span class="badge bg-secondary">@Model.Items[i].SoLuongDat kg</span> × @Model.Items[i].DonGiaThoiDiem.ToString("N0") đ</small>
                </div>
                <span class="fw-bold text-success">@thanhTienRow.ToString("N0") đ</span>
            </div>
        }
        
        <div class="d-flex justify-content-between mt-3 pt-2">
            <span class="fw-bold text-secondary">Tổng tiền tạm tính:</span>
            <span class="h5 text-danger fw-bold">@tongTienTamTinh.ToString("N0") đ</span>
        </div>
    }
    else
    {
        <div class="text-center py-4 text-muted">
            <i class="bi bi-cart-x fs-2"></i>
            <p class="mb-0 mt-2">Không có nông sản nào trong danh sách thanh toán.</p>
        </div>
    }
    
    <div class="alert alert-warning mt-3 mb-0 p-2 rounded-3 border-0" style="font-size: 0.825rem;">
        <i class="bi bi-info-circle-fill"></i> <strong>Lưu ý về trọng lượng:</strong> Đối với phân hệ nông sản tươi sống, trọng lượng thực tế khi cân bốc xếp tại kho sẽ có sai số nhỏ. Số tiền chênh lệch sẽ được đối soát tự động khi hệ thống lập hóa đơn cuối cùng.
    </div>
</div>