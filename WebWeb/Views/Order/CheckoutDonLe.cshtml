@model WebWeb.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán Đơn hàng lẻ trực tuyến";
}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .leaflet-container {
        font-family: inherit;
    }
    
    #map-selection img {
        max-width: none !important;
        max-height: none !important;
    }
</style>

<div class="container mt-4">
    <h2><i class="bi bi-cart-check"></i> Thanh toán Đơn hàng lẻ</h2>
    <hr />

    <div class="row">
        <div class="col-md-7">
            <form asp-action="DatDonHangLe" method="post" class="card p-4 shadow-sm">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <h5 class="mb-3 fw-bold text-dark"><i class="bi bi-geo-alt-fill text-danger"></i> Thông tin nhận nông sản</h5>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold text-success">
                            <i class="bi bi-person-check-fill"></i> Sổ địa chỉ tài khoản của bạn
                        </label>
                        <select asp-for="DiaChiId" 
                                id="SelectDiaChiId"
                                asp-items="@(ViewBag.DanhSachDiaChi as SelectList)" 
                                class="form-select border-success py-2">
                            <option value="">-- Chọn địa chỉ từ sổ địa chỉ --</option>
                        </select>
                        <small class="text-muted d-block mt-1">Hệ thống tự động sử dụng thông tin liên hệ trong hồ sơ tài khoản của bạn.</small>
                    </div>
                    
                    <input type="hidden" asp-for="Email" value="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value" />
                }
                else
                {
                    <div class="bg-light p-3 rounded-3 border border-dashed mb-3">
                        <p class="text-warning small mb-2 fw-semibold">
                            <i class="bi bi-exclamation-triangle-fill"></i> Bạn đang đặt hàng với tư cách Khách vãng lai.
                        </p>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên người nhận nông sản <span class="text-danger">*</span></label>
                            <input type="text" asp-for="NameCusNonAccount" class="form-control" placeholder="Nhập đầy đủ họ tên..." required />
                            <span asp-validation-for="NameCusNonAccount" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại liên hệ <span class="text-danger">*</span></label>
                            <input type="tel" asp-for="PhoneNonAccount" class="form-control" placeholder="Ví dụ: 0912345678..." required />
                            <span asp-validation-for="PhoneNonAccount" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ nhận hàng (*)</label>
                            <input asp-for="AddressNonAccount" id="AddressNonAccount" class="form-control border-success py-2" placeholder="Nhập số nhà, tên đường, phường/xã..." required />
                            <span asp-validation-for="AddressNonAccount" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-success">
                                <i class="bi bi-map"></i> Hoặc chọn vị trí nhanh trên bản đồ
                            </label>
                            <div id="map-selection" class="rounded-3 border shadow-sm" style="height: 350px; width: 100%; position: relative; z-index: 1;"></div>
                            <small class="text-muted"><i class="bi bi-info-circle"></i> Di chuyển bản đồ và click vào vị trí nhà của bạn để hệ thống tự ghi nhận địa chỉ.</small>
                        </div>

                        <input type="hidden" name="KinhDo" id="KinhDoNonAccount" />
                        <input type="hidden" name="ViDo" id="ViDoNonAccount" />
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold">Khung giờ giao hàng nhận nông sản</label>
                    <select asp-for="KhungGioGiaoHang" class="form-select py-2">
                        <option value="Sáng (07:00 - 11:00)">Sáng (07:00 - 11:00)</option>
                        <option value="Chiều (13:00 - 17:00)">Chiều (13:00 - 17:00)</option>
                        <option value="Tối (18:00 - 21:00)">Tối (18:00 - 21:00)</option>
                    </select>
                </div>

                @if (ViewBag.VoucherGoiY != null)
                {
                    <div class="alert alert-success d-flex align-items-center justify-content-between mb-3 rounded-3 border-success border-opacity-20 bg-success bg-opacity-10 py-2 px-3">
                        <div class="small text-success fw-medium">
                            <i class="bi bi-gift-fill me-1"></i> Quà tặng bạn mới: Bạn có mã <strong class="text-danger">@ViewBag.VoucherGoiY</strong> cho đơn hàng đầu tiên!
                        </div>
                        <button type="button" class="btn btn-sm btn-danger py-0 px-2 fw-bold" id="BtnQuickApply" data-code="@ViewBag.VoucherGoiY">
                            Dùng ngay
                        </button>
                    </div>
                }

                <input type="hidden" id="hiddenDiemDung" name="diemDungForm" value="0" />
                <input type="hidden" name="KhuyenMaiId" id="HiddenKhuyenMaiId" value="" />

                <div class="card p-3 mb-3 border-dashed">
                    <label class="form-label fw-bold text-success"><i class="bi bi-ticket-perforated"></i> Mã giảm giá / Voucher</label>
                    <div class="input-group">
                        <input type="text" id="VoucherCodeInput" class="form-control text-uppercase" placeholder="Nhập mã ưu đãi..." />
                        <button type="button" id="BtnApplyVoucher" class="btn btn-success">Áp dụng</button>
                    </div>
                    <div id="VoucherMessage" class="small mt-1 d-none"></div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold d-block">Phương thức thanh toán đơn lẻ</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" asp-for="PhuongThucThanhToan" value="COD" checked>
                        <label class="form-check-label">Thanh toán khi nhận hàng (COD)</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" asp-for="PhuongThucThanhToan" value="VNPAY">
                        <label class="form-check-label">Cổng VNPAY</label>
                    </div>
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" asp-for="PhuongThucThanhToan" value="MOMO">
                        <label class="form-check-label">Ví MoMo</label>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary py-2.5 rounded-3 fw-bold flex-grow-1">
                        <i class="bi bi-arrow-left"></i> QUAY LẠI GIỎ HÀNG
                    </a>
                    
                    <button type="submit" class="btn btn-primary py-2.5 rounded-3 fw-bold flex-grow-1">
                        XÁC NHẬN ĐẶT ĐƠN HÀNG LẺ
                    </button>
                </div>
            </form>
        </div>
        
        <div class="col-md-5">
             @await Html.PartialAsync("_CheckoutSummary", Model)
             <div class="d-flex justify-content-between mt-2">
                <span class="text-secondary">Voucher giảm giá:</span>
                <span id="DiscountDisplay" class="fw-bold text-success">0 đ</span>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <span class="fw-bold text-dark">Tổng tiền thanh toán cuối cùng:</span>
                <span id="FinalAmountDisplay" class="h5 text-danger fw-bold">0 đ</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <script src="~/js/order.js"></script> 
}
<script>
    const listDiaChi = @Html.Raw(ViewBag.DiaChiJson ?? "[]");
    const selectElement = document.getElementById("SelectDiaChiId");

    function autoFillAddress(selectedId) {
        const diaChiDuocChon = listDiaChi.find(d => d.DiaChiId === selectedId);

        if (diaChiDuocChon) {
            if(document.getElementById("NameCusNonAccount")) document.getElementById("NameCusNonAccount").value = diaChiDuocChon.TenNguoiNhan;
            if(document.getElementById("PhoneNonAccount")) document.getElementById("PhoneNonAccount").value = diaChiDuocChon.SoDienThoaiNhan;
            if(document.getElementById("AddressNonAccount")) document.getElementById("AddressNonAccount").value = diaChiDuocChon.DiaChiGiao;
        } else {
            if(document.getElementById("NameCusNonAccount")) document.getElementById("NameCusNonAccount").value = "";
            if(document.getElementById("PhoneNonAccount")) document.getElementById("PhoneNonAccount").value = "";
            if(document.getElementById("AddressNonAccount")) document.getElementById("AddressNonAccount").value = "";
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        // Kiểm tra an toàn cho tài khoản đã đăng nhập
        if (selectElement) {
            const initialId = parseInt(selectElement.value);
            if (initialId) {
                autoFillAddress(initialId);
            }

            selectElement.addEventListener('change', function() {
                autoFillAddress(parseInt(this.value));
            });
        }
    });

</script>