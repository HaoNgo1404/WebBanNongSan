@{
    ViewData["Title"] = "Theo dõi đơn hàng";
}

<link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />

<div class="container py-5 order-shell">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Index">Đơn hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Theo dõi</li>
        </ol>
    </nav>

    <div class="order-card shadow-sm p-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h3 fw-bold mb-1">Theo dõi đơn hàng #FARM-1001</h1>
                <p class="text-muted mb-0">Cập nhật trạng thái giao hàng theo thời gian thực.</p>
            </div>
            <a class="btn btn-outline-secondary" asp-controller="Order" asp-action="Details" asp-route-id="1001">Xem chi tiết</a>
        </div>

        <div class="timeline">
            <div class="timeline-item completed">
                <div class="timeline-icon">✔</div>
                <div>
                    <h6 class="mb-1">Đã đặt hàng</h6>
                    <p class="text-muted mb-0">Đơn hàng đã được tạo thành công.</p>
                </div>
            </div>
            <div class="timeline-item completed">
                <div class="timeline-icon">✔</div>
                <div>
                    <h6 class="mb-1">Đã xác nhận</h6>
                    <p class="text-muted mb-0">Shop đã xác nhận đơn và chuẩn bị hàng.</p>
                </div>
            </div>
            <div class="timeline-item current">
                <div class="timeline-icon">•</div>
                <div>
                    <h6 class="mb-1">Đang chuẩn bị</h6>
                    <p class="text-muted mb-0">Hàng đang được đóng gói và sắp xếp vận chuyển.</p>
                </div>
            </div>
            <div class="timeline-item pending">
                <div class="timeline-icon">•</div>
                <div>
                    <h6 class="mb-1">Đang giao</h6>
                    <p class="text-muted mb-0">Đơn hàng sẽ được bàn giao cho đối tác vận chuyển.</p>
                </div>
            </div>
            <div class="timeline-item pending">
                <div class="timeline-icon">•</div>
                <div>
                    <h6 class="mb-1">Giao thành công</h6>
                    <p class="text-muted mb-0">Đơn hàng sẽ được cập nhật sau khi giao thành công.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-light border mt-4 mb-0">
        <strong>TODO:</strong> Kết nối timeline với dữ liệu vận chuyển khi Backend hoàn thiện.
    </div>
</div>
